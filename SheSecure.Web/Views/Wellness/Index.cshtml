@{
    ViewData["Title"] = "Mood & Wellness";

    var records = (System.Text.Json.JsonElement)ViewBag.Records;
    var burnout = (System.Text.Json.JsonElement)ViewBag.Burnout;
    var trend = (System.Text.Json.JsonElement)ViewBag.Trend;
    var recommendation = (System.Text.Json.JsonElement)ViewBag.Recommendation;

    var hasData = records.EnumerateArray().Any();

    string riskLevel = "", avgMood = "", avgStress = "", recommendationText = "";
    if (burnout.ValueKind == System.Text.Json.JsonValueKind.Object &&
        burnout.TryGetProperty("riskLevel", out var rl))
    {
        riskLevel = rl.GetString() ?? "";
        avgMood = burnout.GetProperty("averageMood").GetDouble().ToString("0.0");
        avgStress = burnout.GetProperty("averageStress").GetDouble().ToString("0.0");
    }
    if (recommendation.ValueKind == System.Text.Json.JsonValueKind.Object &&
        recommendation.TryGetProperty("recommendation", out var rec))
    {
        recommendationText = rec.GetString() ?? "";
    }

    var riskClass = riskLevel == "Low" ? "success"
                  : riskLevel == "Medium" ? "warning"
                  : riskLevel == "High" ? "error"
                  : "neutral";
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4 fade-in-up">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4 fade-in-up">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-md-4">
        <!-- Log Mood Form -->
        <div class="glass-card mb-4 fade-in-up">
            <h5 class="section-title">💜 Log Today's Mood</h5>
            <form method="post" asp-action="Create" class="mt-4">
                <div class="mb-4">
                    <label class="form-label d-flex justify-content-between">
                        <span>Mood Level</span>
                        <span class="text-gradient fw-bold" id="moodVal">(5)</span>
                    </label>
                    <input type="range" name="moodLevel" min="1" max="5" value="5" class="form-range ss-range mb-2" id="moodSlider" oninput="document.getElementById('moodVal').textContent='('+this.value+')'" />
                    <div class="d-flex justify-content-between text-muted" style="font-size: 11px;">
                        <span>😞 Low</span><span>😐 Okay</span><span>😊 Great</span>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label d-flex justify-content-between">
                        <span>Stress Level</span>
                        <span class="text-danger fw-bold" id="stressVal">(3)</span>
                    </label>
                    <input type="range" name="stressLevel" min="1" max="5" value="3" class="form-range ss-range mb-2" id="stressSlider" oninput="document.getElementById('stressVal').textContent='('+this.value+')'" />
                    <div class="d-flex justify-content-between text-muted" style="font-size: 11px;">
                        <span>😌 Calm</span><span>😤 Moderate</span><span>🤯 High</span>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Notes (optional)</label>
                    <textarea name="remarks" rows="3" class="form-control" placeholder="How are you feeling today?" style="resize: none;"></textarea>
                </div>
                <button type="submit" class="btn-ss w-100 py-2 ripple">
                    <i class="bi bi-heart-pulse me-2"></i>Log Mood
                </button>
            </form>
        </div>

        <!-- Burnout Risk Card -->
        @if (!string.IsNullOrEmpty(riskLevel))
        {
            <div class="glass-card mb-4 fade-in-up delay-100 hover-lift">
                <h5 class="section-title">🔥 Burnout Risk</h5>
                <div class="d-flex align-items-center justify-content-between mt-3 mb-4">
                    <span class="fw-bold" style="font-size: 26px; color: var(--ss-text);">@riskLevel</span>
                    <span class="status-chip @riskClass">Risk Level</span>
                </div>
                <div class="d-flex gap-4">
                    <div>
                        <div class="fw-bold text-gradient" style="font-size: 20px;">@avgMood</div>
                        <div class="text-muted" style="font-size: 12px;">Avg Mood</div>
                    </div>
                    <div>
                        <div class="fw-bold text-danger" style="font-size: 20px;">@avgStress</div>
                        <div class="text-muted" style="font-size: 12px;">Avg Stress</div>
                    </div>
                </div>
            </div>
        }

        <!-- Recommendation Card -->
        @if (!string.IsNullOrEmpty(recommendationText))
        {
            <div class="glass-card-sm border-start border-4 border-info fade-in-up delay-200 hover-lift" style="border-radius: 8px;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-lightbulb text-info"></i>
                    <span class="fw-medium text-white" style="font-size: 14px;">Recommendation</span>
                </div>
                <div style="font-size: 13px; color: var(--ss-muted); line-height: 1.6;">
                    @recommendationText
                </div>
            </div>
        }
    </div>

    <!-- Right Column -->
    <div class="col-md-8">
        <!-- Trend Chart -->
        @if (trend.EnumerateArray().Any())
        {
            <div class="glass-card mb-4 fade-in-up delay-100 hover-lift">
                <h5 class="section-title">📈 Mood & Stress Trend</h5>
                <div class="mt-3">
                    <canvas id="trendChart" height="120"></canvas>
                </div>
            </div>
        }

        <!-- Mood History Table -->
        <div class="glass-card h-100 fade-in-up delay-200">
            <h5 class="section-title">🗓 Mood History</h5>
            @if (!hasData)
            {
                <div class="empty-state">
                    <div class="empty-state-icon" style="animation: float 5s ease-in-out infinite;">💜</div>
                    <h5 class="text-white">No mood logs yet</h5>
                    <p>Log your first mood to start tracking your wellness.</p>
                </div>
            }
            else
            {
                <style>
                    .mood-card {
                        background: rgba(30, 41, 59, 0.4);
                        border: 1px solid rgba(255,255,255,0.05);
                        border-radius: 12px;
                        padding: 16px 20px;
                        margin-bottom: 12px;
                        transition: all 0.3s ease;
                        display: flex;
                        align-items: center;
                        gap: 20px;
                    }
                    .mood-card:hover {
                        background: rgba(30, 41, 59, 0.7);
                        transform: translateY(-2px);
                        border-color: rgba(255,255,255,0.1);
                        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
                    }
                    .mood-metric {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        width: 50px;
                        height: 50px;
                        border-radius: 12px;
                        background: rgba(255,255,255,0.03);
                    }
                </style>
                <div class="mt-3">
                    @foreach (var r in records.EnumerateArray())
                    {
                        var date = r.GetProperty("createdAt").GetString();
                        var mood = r.GetProperty("moodLevel").GetInt32();
                        var stress = r.GetProperty("stressLevel").GetInt32();
                        var remarks = r.TryGetProperty("remarks", out var rem) &&
                                       rem.ValueKind != System.Text.Json.JsonValueKind.Null
                                       ? rem.GetString() : "No notes provided";

                        var moodEmoji = mood >= 4 ? "😊" : mood >= 3 ? "😐" : "😞";
                        var stressEmoji = stress >= 4 ? "🤯" : stress >= 3 ? "😤" : "😌";
                        
                        var moodColor = mood >= 4 ? "var(--ss-success)" : mood >= 3 ? "var(--ss-warning)" : "var(--ss-error)";
                        var stressColor = stress >= 4 ? "var(--ss-error)" : stress >= 3 ? "var(--ss-warning)" : "var(--ss-success)";

                        <div class="mood-card fade-in-up">
                            <div class="d-flex gap-3">
                                <div class="mood-metric" style="border: 1px solid rgba(255,255,255,0.05);">
                                    <span style="font-size: 18px;">@moodEmoji</span>
                                    <span style="font-size: 10px; font-weight: 600; color: @moodColor;">@mood/5</span>
                                </div>
                                <div class="mood-metric" style="border: 1px solid rgba(255,255,255,0.05);">
                                    <span style="font-size: 18px;">@stressEmoji</span>
                                    <span style="font-size: 10px; font-weight: 600; color: @stressColor;">@stress/5</span>
                                </div>
                            </div>
                            
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-calendar-event text-muted" style="font-size: 12px;"></i>
                                    <span class="text-white fw-medium" style="font-size: 13px;">@DateTime.Parse(date!).ToString("dd MMM yyyy, hh:mm tt")</span>
                                </div>
                                <div style="font-size: 13px; color: var(--ss-muted); line-height: 1.4;">
                                    @if(remarks == "No notes provided") {
                                        <span class="fst-italic opacity-50">@remarks</span>
                                    } else {
                                        <span>@remarks</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .ss-range::-webkit-slider-thumb {
        background: var(--ss-accent);
    }
    .ss-range::-webkit-slider-runnable-track {
        background: rgba(255,255,255,0.1);
    }
</style>

@section Scripts {
    <script>
        @if (trend.EnumerateArray().Any())
        {
                var trendDates = trend.EnumerateArray()
                        .Select(x => DateTime.Parse(x.GetProperty("date").GetString()!).ToString("dd MMM"))
                        .ToList();
                var moodData = trend.EnumerateArray()
                        .Select(x => x.GetProperty("moodLevel").GetInt32()).ToList();
                var stressData = trend.EnumerateArray()
                        .Select(x => x.GetProperty("stressLevel").GetInt32()).ToList();

                <text>
                    new Chart(document.getElementById('trendChart'), {
                        type: 'line',
                        data: {
                            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(trendDates)),
                            datasets: [
                                {
                                    label: 'Mood',
                                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(moodData)),
                                    borderColor: '#a855f7',
                                    backgroundColor: 'rgba(168,85,247,0.1)',
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#a855f7'
                                },
                                {
                                    label: 'Stress',
                                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stressData)),
                                    borderColor: '#10b981',
                                    backgroundColor: 'rgba(16,185,129,0.1)',
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#10b981'
                                }
                            ]
                        },
                        options: {
                            plugins: { legend: { labels: { color: '#94a3b8' } } },
                            scales: {
                                x: { ticks: { color: '#94a3b8' }, grid: { color: '#2d3748', borderDash: [5,5] } },
                                y: {
                                    ticks: { color: '#94a3b8' },
                                    grid: { color: '#2d3748', borderDash: [5,5] },
                                    min: 0, max: 5
                                }
                            }
                        }
                    });
                </text>
        }
    </script>
}
