@{
    ViewData["Title"] = "User Management";
    var users = (System.Text.Json.JsonElement)ViewBag.Users;
    var currentUserId = Context.Session.GetString("UserId");
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="section-title text-primary mb-1"><i class="bi bi-people-fill me-2"></i>Directory</h5>
            <p class="text-muted" style="font-size: 14px;">Manage system access and assign roles to registered users.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover" style="background: transparent; margin-bottom: 0;">
            <thead style="background: rgba(255,255,255,0.05);">
                <tr>
                    <th class="text-muted fw-normal" style="font-size: 13px;">Name</th>
                    <th class="text-muted fw-normal" style="font-size: 13px;">Email</th>
                    <th class="text-muted fw-normal" style="font-size: 13px;">Role</th>
                    <th class="text-muted fw-normal text-end" style="font-size: 13px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users.EnumerateArray())
                {
                    var id = user.GetProperty("id").GetString();
                    var name = user.GetProperty("fullName").GetString() ?? "Unknown";
                    var email = user.GetProperty("email").GetString() ?? "Unknown";
                    var role = user.GetProperty("role").GetString() ?? "Employee";

                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <td class="align-middle">
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar bg-primary bg-opacity-25 text-primary" style="width: 32px; height: 32px; font-size: 12px;">
                                    @(name.Length > 0 ? name[0].ToString().ToUpper() : "U")
                                </div>
                                <span class="text-white fw-bold" style="font-size: 14px;">@name</span>
                            </div>
                        </td>
                        <td class="align-middle text-white opacity-75" style="font-size: 14px;">
                            @email
                        </td>
                        <td class="align-middle">
                            <form method="post" asp-action="ChangeRole" class="d-flex align-items-center m-0">
                                <input type="hidden" name="userId" value="@id" />
                                <select name="newRole" class="form-select form-select-sm bg-dark text-white border-secondary" style="width: 140px; font-size: 13px;" onchange="this.form.submit()" @(id == currentUserId ? "disabled" : "")>
                                    <option value="Employee" selected="@(role == "Employee" ? "selected" : null)">Employee</option>
                                    <option value="Manager" selected="@(role == "Manager" ? "selected" : null)">Manager</option>
                                    <option value="HR" selected="@(role == "HR" ? "selected" : null)">HR / POSH</option>
                                    <option value="Security" selected="@(role == "Security" ? "selected" : null)">Security</option>
                                    <option value="Admin" selected="@(role == "Admin" ? "selected" : null)">Admin</option>
                                </select>
                            </form>
                        </td>
                        <td class="align-middle text-end">
                            @if (id != currentUserId)
                            {
                                <form method="post" asp-action="DeleteUser" class="m-0 d-inline" onsubmit="return confirm('Are you sure you want to permanently delete @email?');">
                                    <input type="hidden" name="userId" value="@id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Remove User">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-secondary opacity-50 px-2 py-1">You</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
