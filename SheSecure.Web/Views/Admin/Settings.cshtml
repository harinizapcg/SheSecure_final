@{
    ViewData["Title"] = "System Settings";
    var settings = (System.Text.Json.JsonElement)ViewBag.Settings;
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="section-title text-primary mb-1"><i class="bi bi-sliders me-2"></i>Global Configuration</h5>
            <p class="text-muted" style="font-size: 14px;">Update system-wide settings, timers, and alerts without restarting the server.</p>
        </div>
    </div>

    <div class="row row-cols-1 g-4">
        @foreach (var setting in settings.EnumerateArray())
        {
            var key = setting.GetProperty("settingKey").GetString();
            var val = setting.GetProperty("settingValue").GetString();
            var desc = setting.GetProperty("description").GetString();

            <div class="col">
                <div class="p-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <form method="post" asp-action="UpdateSetting" class="m-0 d-flex flex-column flex-md-row gap-3 align-items-md-start">
                        <input type="hidden" name="key" value="@key" />
                        
                        <div class="flex-grow-1">
                            <label class="form-label text-white fw-bold mb-1" style="font-size: 15px;">@key.Replace("_", " ")</label>
                            <p class="text-muted mb-3 mb-md-0" style="font-size: 13px;">@desc</p>
                        </div>
                        
                        <div class="d-flex gap-2 align-items-start">
                            <input type="text" name="value" class="form-control bg-dark text-white border-secondary" value="@val" style="width: 250px; font-size: 14px;" required />
                            <button type="submit" class="btn btn-primary px-3" style="font-size: 14px;">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        @if (settings.GetArrayLength() == 0)
        {
            <div class="col text-center py-5 text-muted">
                <i class="bi bi-gear-wide-connected fs-1 mb-2 d-block opacity-50"></i>
                <p>No system settings found.</p>
            </div>
        }
    </div>
</div>
