@{
    ViewData["Title"] = "Notifications";
    var notifications = (System.Text.Json.JsonElement)ViewBag.Notifications;
    var list = notifications.EnumerateArray().ToList();
    var unreadCount = list.Count(n => !n.GetProperty("isRead").GetBoolean());
}

<div class="row g-4">
    <div class="col-md-8 mx-auto">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h4 class="mb-1 fw-bold text-white">🔔 Notifications</h4>
                @if (unreadCount > 0)
                {
                    <span class="status-chip error mt-2" style="font-size: 12px; padding: 4px 10px;">
                        @unreadCount unread
                    </span>
                }
            </div>
        </div>

        @if (!list.Any())
        {
            <div class="glass-card text-center py-5">
                <div class="empty-state-icon mb-3" style="font-size: 48px;">🔔</div>
                <h5 class="text-white">All caught up!</h5>
                <p class="text-muted">You have no notifications.</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var n in list)
                {
                    var id = n.GetProperty("id").GetInt32();
                    var title = n.GetProperty("title").GetString();
                    var message = n.GetProperty("message").GetString();
                    var type = n.GetProperty("type").GetString();
                    var isRead = n.GetProperty("isRead").GetBoolean();
                    var createdAt = n.GetProperty("createdAt").GetString();

                    var typeIcon = type == "Complaint" ? "📋"
                                 : type == "Safety" ? "🛡"
                                 : type == "Wellness" ? "💜"
                                 : type == "Emergency" ? "🚨"
                                 : "🔔";

                    var typeClass = type == "Complaint" ? "warning"
                                  : type == "Safety" ? "success"
                                  : type == "Wellness" ? "info"
                                  : type == "Emergency" ? "error"
                                  : "neutral";

                    <div class="glass-card @(isRead ? "opacity-75" : "")" style="padding: 20px; transition: all 0.3s ease; border-left: 4px solid @(!isRead ? "var(--ss-accent)" : "transparent");">
                        <div class="d-flex gap-3">
                            <div class="status-chip @typeClass d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; border-radius: 12px; font-size: 24px;">
                                @typeIcon
                            </div>

                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="mb-0 fw-bold @(isRead ? "text-muted" : "text-white")">
                                        @title
                                        @if (!isRead)
                                        {
                                            <span class="badge bg-danger ms-2 rounded-circle p-1" style="width: 8px; height: 8px; display: inline-block;"></span>
                                        }
                                    </h6>
                                    <span style="font-size: 12px; color: var(--ss-muted);">
                                        @DateTime.Parse(createdAt!).ToString("dd MMM, hh:mm tt")
                                    </span>
                                </div>
                                <p class="mb-3" style="font-size: 14px; color: var(--ss-text);">
                                    @message
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="status-chip @typeClass" style="font-size: 11px;">@type</span>
                                    @if (!isRead)
                                    {
                                        <form method="post" asp-action="MarkRead" class="m-0">
                                            <input type="hidden" name="id" value="@id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success border-0" style="background: rgba(16,185,129,0.1); border-radius: 6px; font-size: 12px;">
                                                <i class="bi bi-check2-all me-1"></i>Mark as read
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size: 12px;"><i class="bi bi-check2 me-1"></i>Read</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
