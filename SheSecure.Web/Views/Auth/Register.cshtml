@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SheSecure — Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .split-layout {
            display: flex;
            min-height: 100vh;
        }
        .split-left {
            flex: 1;
            background: linear-gradient(135deg, rgba(233, 69, 96, 0.1), rgba(168, 85, 247, 0.1)), url('https://images.unsplash.com/photo-1573164713988-8665fc963095?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80') center/cover;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .split-left::after {
            content: '';
            position: absolute;
            top:0; left:0; right:0; bottom:0;
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(4px);
        }
        .left-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 40px;
        }
        .split-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            background: var(--ss-bg);
        }
        .auth-container {
            width: 100%;
            max-width: 440px;
        }
        @@media (max-width: 768px) {
            .split-left { display: none; }
        }
        
        .brand-logo-large {
            width: 80px; height: 80px;
            background: linear-gradient(135deg, var(--ss-accent), var(--ss-accent2));
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 40px;
            margin: 0 auto 24px;
            box-shadow: 0 10px 25px rgba(233, 69, 96, 0.4);
        }
    </style>
</head>
<body>
    <div class="split-layout">
        <div class="split-left">
            <div class="left-content">
                <div class="brand-logo-large">🛡️</div>
                <h1 class="text-gradient mb-3" style="font-size: 42px; font-weight: 800;">SheSecure</h1>
                <p style="font-size: 18px; color: var(--ss-text); max-width: 400px; margin: 0 auto;">
                    A comprehensive, modern workplace safety and employee wellness platform.
                </p>
            </div>
        </div>
        <div class="split-right">
            <div class="auth-container">
                <div class="glass-card">
                    <h2 class="page-title text-center mb-1">Create Account</h2>
                    <p class="text-center mb-4" style="color: var(--ss-muted); font-size: 14px;">Join SheSecure today</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert-glass error mb-4">
                            <i class="bi bi-exclamation-circle"></i> <span>@ViewBag.Error</span>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="fullName" class="form-control" placeholder="Priya Sharma" required autofocus />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email address</label>
                            <input type="email" name="email" class="form-control" placeholder="you@company.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <div class="input-group">
                                <input type="password" name="password" id="pwdField" class="form-control" placeholder="Min 8 chars" required style="border-right: none;" />
                                <span class="input-group-text" id="togglePwd" style="background: rgba(15, 23, 42, 0.6); border-left: none; border-color: var(--ss-border); color: var(--ss-muted); cursor: pointer;">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </span>
                            </div>
                            <div style="font-size: 11px; color: var(--ss-muted); margin-top: 6px;">
                                <i class="bi bi-info-circle"></i> Must include uppercase, number and special char (e.g. Test@1234)
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Role</label>
                            <select name="role" class="form-select" required>
                                <option value="" disabled selected>Select your role</option>
                                <option value="Employee">Employee</option>
                                <option value="Manager">Manager</option>
                                <option value="HR">HR</option>
                                <option value="Security">Security</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn-ss w-100 py-2" style="font-size: 16px;">Create Account</button>

                        <div class="mt-4 text-center" style="font-size: 14px; color: var(--ss-muted);">
                            Already have an account? <a href="/Auth/Login" class="text-gradient fw-bold text-decoration-none">Sign in</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var toggle = document.getElementById('togglePwd');
            var pwd = document.getElementById('pwdField');
            var icon = document.getElementById('eyeIcon');
            if (!toggle || !pwd) return;
            
            var group = toggle.parentElement;
            pwd.addEventListener('focus', function() {
                group.style.boxShadow = '0 0 0 3px rgba(168, 85, 247, 0.15)';
                pwd.style.borderColor = 'var(--ss-accent2)';
                toggle.style.borderColor = 'var(--ss-accent2)';
            });
            pwd.addEventListener('blur', function() {
                group.style.boxShadow = 'none';
                pwd.style.borderColor = 'var(--ss-border)';
                toggle.style.borderColor = 'var(--ss-border)';
            });

            toggle.addEventListener('click', function () {
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    if (icon) icon.className = 'bi bi-eye-slash';
                } else {
                    pwd.type = 'password';
                    if (icon) icon.className = 'bi bi-eye';
                }
            });
        })();
    </script>
</body>
</html>
