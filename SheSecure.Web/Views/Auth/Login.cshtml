@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SheSecure — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --ss-bg:      #1a1a2e;
            --ss-card:    #16213e;
            --ss-accent:  #e94560;
            --ss-accent2: #a855f7;
            --ss-border:  #2d3748;
            --ss-text:    #e2e8f0;
            --ss-muted:   #94a3b8;
        }
        body {
            background: var(--ss-bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        .login-card {
            background: var(--ss-card);
            border: 1px solid var(--ss-border);
            border-radius: 16px;
            padding: 40px 36px;
            width: 100%;
            max-width: 400px;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
            justify-content: center;
        }
        .logo-icon {
            width: 42px; height: 42px;
            background: linear-gradient(135deg, var(--ss-accent), var(--ss-accent2));
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
        }
        .brand-name {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--ss-accent), var(--ss-accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .page-subtitle {
            font-size: 13px;
            color: var(--ss-muted);
            text-align: center;
            margin-bottom: 28px;
        }
        .form-label {
            color: var(--ss-muted);
            font-size: 13px;
            margin-bottom: 6px;
        }
        .form-control {
            background: #0f3460;
            border: 1px solid var(--ss-border);
            color: var(--ss-text);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 14px;
        }
        .form-control:focus {
            background: #0f3460;
            border-color: var(--ss-accent);
            color: var(--ss-text);
            box-shadow: 0 0 0 3px rgba(233,69,96,0.15);
        }
        .input-group-text {
            background: #0f3460;
            border: 1px solid var(--ss-border);
            color: var(--ss-muted);
            border-radius: 0 8px 8px 0;
            cursor: pointer;
        }
        .btn-login {
            background: linear-gradient(135deg, var(--ss-accent), var(--ss-accent2));
            border: none;
            color: white;
            border-radius: 8px;
            padding: 11px;
            font-size: 14px;
            font-weight: 600;
            width: 100%;
            margin-top: 8px;
            transition: opacity 0.2s;
        }
        .btn-login:hover { opacity: 0.9; color: white; }
        .error-box {
            background: rgba(233,69,96,0.1);
            border: 1px solid rgba(233,69,96,0.3);
            color: #f87171;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .success-box {
            background: rgba(29,158,117,0.1);
            border: 1px solid rgba(29,158,117,0.3);
            color: #34d399;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .divider { border-color: var(--ss-border); margin: 20px 0; }
        .register-link {
            text-align: center;
            font-size: 13px;
            color: var(--ss-muted);
        }
        .register-link a { color: var(--ss-accent2); text-decoration: none; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <div class="logo-icon">🛡️</div>
            <span class="brand-name">SheSecure</span>
        </div>
        <div class="page-subtitle">Workplace Safety &amp; Support Platform</div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="success-box">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" name="email" class="form-control"
                       placeholder="you@company.com" required autofocus />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="input-group">
                    <input type="password" name="password" id="pwdField"
                           class="form-control" placeholder="••••••••" required />
                    <span class="input-group-text" id="togglePwd" title="Show / hide password">
                        <i class="bi bi-eye" id="toggleIcon"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn-login">Sign in</button>

            <hr class="divider" />

            <div class="register-link">
                Don't have an account? <a href="/Auth/Register">Register</a>
            </div>
        </form>
    </div>

    <script>
        (function () {
            var toggle = document.getElementById('togglePwd');
            var pwd = document.getElementById('pwdField');
            var icon = document.getElementById('toggleIcon');
            if (!toggle || !pwd) return;
            toggle.addEventListener('click', function () {
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    if (icon) icon.className = 'bi bi-eye-slash';
                } else {
                    pwd.type = 'password';
                    if (icon) icon.className = 'bi bi-eye';
                }
            });
        })();
    </script>
</body>
</html>