@{
    ViewData["Title"] = "Dashboard";
    var role = Context.Session.GetString("Role") ?? "";
    var userName = Context.Session.GetString("UserName") ?? "";

    var stats = (System.Text.Json.JsonElement)ViewBag.Stats;
    var complaints = (System.Text.Json.JsonElement)ViewBag.Complaints;
    var wellness = (System.Text.Json.JsonElement)ViewBag.Wellness;
    var emergency = (System.Text.Json.JsonElement)ViewBag.Emergency;

    var totalComplaints = stats.GetProperty("totalComplaints").GetInt32();
    var openComplaints = stats.GetProperty("openComplaints").GetInt32();
    var resolvedComplaints = stats.GetProperty("resolvedComplaints").GetInt32();
    var wellnessRequests = stats.GetProperty("wellnessRequests").GetInt32();
    var activeAlerts = stats.GetProperty("activeEmergencyAlerts").GetInt32();
    var notificationsSent = stats.GetProperty("notificationsSent").GetInt32();
}

<!-- Welcome Hero -->
<div class="glass-panel p-5 mb-4 gradient-bg-animated" style="position: relative; overflow: hidden; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 40px rgba(0,0,0,0.4);">
    <!-- Floating Shapes -->
    <div class="floating-shape" style="width: 400px; height: 400px; background: var(--ss-accent); top: -150px; right: -100px; animation-delay: 0s; opacity: 0.15;"></div>
    <div class="floating-shape" style="width: 300px; height: 300px; background: var(--ss-safety); bottom: -100px; left: 5%; animation-delay: 2s; opacity: 0.15;"></div>
    <div class="floating-shape" style="width: 350px; height: 350px; background: var(--ss-accent2); top: 50%; right: 30%; transform: translateY(-50%); animation-delay: 4s; opacity: 0.1;"></div>
    
    <div class="position-relative d-flex flex-column gap-4 fade-in-up" style="z-index: 1;">
        <!-- Top row: Date & System Status -->
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div style="font-size: 13px; font-weight: 500; color: var(--ss-muted); text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; background: rgba(255,255,255,0.05); padding: 6px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
                <i class="bi bi-calendar3 me-2" style="color: var(--ss-accent);"></i>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")
            </div>
            <div class="d-flex align-items-center px-3 py-1 hover-lift" style="background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 20px; cursor: default;">
                <div style="width: 8px; height: 8px; border-radius: 50%; background: #10b981; margin-right: 8px; box-shadow: 0 0 8px #10b981; animation: pulse-ring 2s infinite;"></div>
                <span style="font-size: 12px; font-weight: 600; color: #10b981; text-transform: uppercase; letter-spacing: 0.5px;">Systems Operational</span>
            </div>
        </div>

        <!-- Main Content -->
        <div class="d-flex align-items-center gap-4 mt-2">
            <div style="font-size: 72px; text-shadow: 0 8px 25px rgba(0,0,0,0.4); animation: float 6s ease-in-out infinite;">👋</div>
            <div>
                <h1 class="mb-2 fw-bold text-white" style="letter-spacing: -0.03em; font-size: 42px;">Welcome back, <span class="text-gradient" style="background: linear-gradient(135deg, #fff, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">@userName</span></h1>
                <p class="mb-0" style="font-size: 18px; color: rgba(255,255,255,0.7); font-weight: 400; max-width: 600px; line-height: 1.6;">
                    Prioritizing your safety and well-being every day. Quickly access your essential tools below.
                </p>
            </div>
        </div>

        <!-- Hero Quick Actions -->
        <div class="d-flex flex-wrap gap-3 mt-3">
            @if (role == "Employee" || role == "Manager" || role == "HR" || role == "Admin")
            {
                <a asp-controller="SafeReach" asp-action="Index" class="btn-ss text-decoration-none hover-lift d-flex align-items-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(10px); padding: 12px 24px; font-size: 15px; border-radius: 12px; transition: all 0.3s ease;">
                    <i class="bi bi-shield-check me-2" style="color: var(--ss-safety); font-size: 18px;"></i>Safe Check-In
                </a>
                <a asp-controller="Complaint" asp-action="Index" class="btn-ss text-decoration-none hover-lift d-flex align-items-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(10px); padding: 12px 24px; font-size: 15px; border-radius: 12px; transition: all 0.3s ease;">
                    <i class="bi bi-file-earmark-text me-2" style="color: var(--ss-warning); font-size: 18px;"></i>Raise Complaint
                </a>
            }
            <button onclick="triggerSOS()" class="btn-ss text-decoration-none hover-lift d-flex align-items-center position-relative" style="background: linear-gradient(135deg, rgba(239,68,68,0.15), rgba(220,38,38,0.3)); border: 1px solid rgba(239,68,68,0.4); backdrop-filter: blur(10px); padding: 12px 24px; font-size: 15px; border-radius: 12px; color: white; overflow: hidden; transition: all 0.3s ease;">
                <span class="position-absolute w-100 h-100" style="inset: 0; background: radial-gradient(circle, rgba(239,68,68,0.4) 0%, transparent 70%); animation: pulse-sos 2s infinite; pointer-events: none;"></span>
                <i class="bi bi-exclamation-triangle-fill me-2 position-relative" style="color: #fca5a5; font-size: 18px; z-index: 1;"></i>
                <span class="position-relative fw-bold" style="z-index: 1;">Emergency SOS</span>
            </button>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<style>
    .kpi-card-premium {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        padding: 24px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
    }
    .kpi-card-premium::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: var(--kpi-gradient, linear-gradient(90deg, transparent, transparent));
        opacity: 0.8;
    }
    .kpi-card-premium:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5), 0 0 25px var(--kpi-glow, rgba(255,255,255,0));
        border-color: rgba(255, 255, 255, 0.15);
    }
    .kpi-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
        background: var(--kpi-gradient);
        box-shadow: 0 8px 20px var(--kpi-glow);
    }
    .kpi-value {
        font-size: 36px;
        font-weight: 800;
        letter-spacing: -1px;
        color: white;
        line-height: 1.2;
    }
    .kpi-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--ss-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 4px;
    }
    .kpi-trend {
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 20px;
        background: rgba(255,255,255,0.05);
    }
</style>

<div class="row g-4 mb-5 mt-2">
    <!-- Total Complaints -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-100">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #6366f1, #8b5cf6); --kpi-glow: rgba(99, 102, 241, 0.4);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-clipboard-data"></i>
                </div>
                <div class="kpi-trend" style="color: #34d399; background: rgba(52, 211, 153, 0.1);">
                    <i class="bi bi-arrow-up-right"></i>12%
                </div>
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@totalComplaints">0</div>
                <div class="kpi-label">Total Complaints</div>
            </div>
        </div>
    </div>
    
    <!-- Open Complaints -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-100">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #f59e0b, #ea580c); --kpi-glow: rgba(245, 158, 11, 0.4);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="kpi-trend" style="color: #f87171; background: rgba(248, 113, 113, 0.1);">
                    <i class="bi bi-arrow-up-right"></i>3%
                </div>
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@openComplaints">0</div>
                <div class="kpi-label">Open Complaints</div>
            </div>
        </div>
    </div>

    <!-- Resolved Complaints -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-100">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #10b981, #059669); --kpi-glow: rgba(16, 185, 129, 0.4);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <div class="kpi-trend" style="color: #34d399; background: rgba(52, 211, 153, 0.1);">
                    <i class="bi bi-arrow-up-right"></i>8%
                </div>
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@resolvedComplaints">0</div>
                <div class="kpi-label">Resolved Complaints</div>
            </div>
        </div>
    </div>

    <!-- Wellness Requests -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-200">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #ec4899, #be185d); --kpi-glow: rgba(236, 72, 153, 0.4);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <div class="kpi-trend" style="color: #34d399; background: rgba(52, 211, 153, 0.1);">
                    <i class="bi bi-arrow-up-right"></i>15%
                </div>
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@wellnessRequests">0</div>
                <div class="kpi-label">Wellness Requests</div>
            </div>
        </div>
    </div>

    <!-- Active SOS Alerts -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-200">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #ef4444, #b91c1c); --kpi-glow: rgba(239, 68, 68, 0.6); border: 1px solid rgba(239, 68, 68, 0.3);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper" style="animation: pulse-sos 2s infinite;">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                @if (activeAlerts > 0)
                {
                    <div class="kpi-trend" style="color: #ef4444; background: rgba(239, 68, 68, 0.15); animation: pulse-ring 1s infinite;">
                        ACTION REQUIRED
                    </div>
                }
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@activeAlerts" style="color: #fca5a5;">0</div>
                <div class="kpi-label" style="color: #fca5a5;">Active SOS Alerts</div>
            </div>
        </div>
    </div>

    <!-- Notifications Sent -->
    <div class="col-xl-4 col-md-6 fade-in-up delay-200">
        <div class="kpi-card-premium h-100" style="--kpi-gradient: linear-gradient(135deg, #0ea5e9, #0284c7); --kpi-glow: rgba(14, 165, 233, 0.4);">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-bell"></i>
                </div>
                <div class="kpi-trend" style="color: var(--ss-muted);">
                    <i class="bi bi-dash"></i>0%
                </div>
            </div>
            <div>
                <div class="kpi-value animated-counter" data-target="@notificationsSent">0</div>
                <div class="kpi-label">Notifications Sent</div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-md-4 fade-in-up delay-300">
        <div class="glass-card h-100 p-4 hover-lift">
            <h5 class="section-title">🗂 Complaints by Category</h5>
            <div class="mt-4">
                <canvas id="complaintsChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4 fade-in-up delay-300">
        <div class="glass-card h-100 p-4 hover-lift">
            <h5 class="section-title">💜 Wellness Requests</h5>
            <div class="mt-4">
                <canvas id="wellnessChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4 fade-in-up delay-300">
        <div class="glass-card h-100 p-4 hover-lift">
            <h5 class="section-title">🚨 Emergency Alert Status</h5>
            <div class="mt-4">
                <canvas id="emergencyChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="glass-card p-4 fade-in-up delay-300">
    <h5 class="section-title">⚡ Quick Actions</h5>
    <div class="d-flex flex-wrap gap-3 mt-4">
        @if (role == "Employee" || role == "Manager" || role == "HR" || role == "Admin")
        {
            <a asp-controller="SafeReach" asp-action="Index" class="btn-ss text-decoration-none hover-lift">
                <i class="bi bi-shield-check me-2"></i>Safe Check-In
            </a>
            <a asp-controller="Wellness" asp-action="Index" class="btn-ss text-decoration-none hover-lift">
                <i class="bi bi-heart-pulse me-2"></i>Log Mood
            </a>
            <a asp-controller="Complaint" asp-action="Index" class="btn-ss text-decoration-none hover-lift">
                <i class="bi bi-file-earmark-text me-2"></i>Raise Complaint
            </a>
            <a asp-controller="WFH" asp-action="Index" class="btn-ss text-decoration-none hover-lift">
                <i class="bi bi-house-door me-2"></i>WFH Request
            </a>
        }
        @if (role == "HR" || role == "Admin")
        {
            <a asp-controller="Complaint" asp-action="All" class="btn-ss text-decoration-none hover-lift" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);">
                <i class="bi bi-folder2-open me-2"></i>All Complaints
            </a>
        }
        @if (role == "Manager" || role == "Admin")
        {
            <a asp-controller="WFH" asp-action="Approvals" class="btn-ss text-decoration-none hover-lift" style="background: linear-gradient(135deg, #10b981, #059669);">
                <i class="bi bi-check2-square me-2"></i>WFH Approvals
            </a>
        }
        @if (role == "Security" || role == "Admin")
        {
            <a asp-controller="Emergency" asp-action="All" class="btn-ss text-decoration-none hover-lift" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                <i class="bi bi-bell-fill me-2"></i>View All Alerts
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Number Counter Animation
        document.querySelectorAll('.animated-counter').forEach(counter => {
            const updateCount = () => {
                const target = +counter.getAttribute('data-target');
                const count = +counter.innerText;
                const speed = 40; 
                const inc = target / speed;
                
                if(count < target) {
                    counter.innerText = Math.ceil(count + inc);
                    setTimeout(updateCount, 20);
                } else {
                    counter.innerText = target;
                }
            };
            updateCount();
        });

        // Build chart data from server
        const complaintLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    complaints.EnumerateArray().Select(x => x.GetProperty("category").GetString()).ToList()
            ));
        const complaintData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    complaints.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const wellnessLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    wellness.EnumerateArray().Select(x => x.GetProperty("requestType").GetString()).ToList()
            ));
        const wellnessData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    wellness.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const emergencyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    emergency.EnumerateArray().Select(x => x.GetProperty("status").GetString()).ToList()
            ));
        const emergencyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    emergency.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const chartDefaults = {
            plugins: { legend: { labels: { color: '#94a3b8', font: { size: 12, family: "'Inter', sans-serif" } } } }
        };

        // Complaints Doughnut
        new Chart(document.getElementById('complaintsChart'), {
            type: 'doughnut',
            data: {
                labels: complaintLabels,
                datasets: [{
                    data: complaintData,
                    backgroundColor: ['#e94560','#0ea5e9','#a855f7'],
                    borderWidth: 0
                }]
            },
            options: { ...chartDefaults, cutout: '70%' }
        });

        // Wellness Bar
        new Chart(document.getElementById('wellnessChart'), {
            type: 'bar',
            data: {
                labels: wellnessLabels,
                datasets: [{
                    label: 'Requests',
                    data: wellnessData,
                    backgroundColor: ['#a855f7','#e94560'],
                    borderRadius: 8,
                    borderWidth: 0
                }]
            },
            options: {
                ...chartDefaults,
                scales: {
                    x: { ticks: { color: '#94a3b8' }, grid: { color: '#2d3748', borderDash: [5, 5] } },
                    y: { ticks: { color: '#94a3b8' }, grid: { color: '#2d3748', borderDash: [5, 5] } }
                }
            }
        });

        // Emergency Pie
        new Chart(document.getElementById('emergencyChart'), {
            type: 'doughnut',
            data: {
                labels: emergencyLabels,
                datasets: [{
                    data: emergencyData,
                    backgroundColor: ['#ef4444','#10b981'],
                    borderWidth: 0
                }]
            },
            options: { ...chartDefaults, cutout: '70%' }
        });
    </script>
}
