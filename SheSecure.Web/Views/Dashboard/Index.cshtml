@{
    ViewData["Title"] = "Dashboard";
    var role = Context.Session.GetString("Role") ?? "";
    var userName = Context.Session.GetString("UserName") ?? "";

    var stats = (System.Text.Json.JsonElement)ViewBag.Stats;
    var complaints = (System.Text.Json.JsonElement)ViewBag.Complaints;
    var wellness = (System.Text.Json.JsonElement)ViewBag.Wellness;
    var emergency = (System.Text.Json.JsonElement)ViewBag.Emergency;

    var totalComplaints = stats.GetProperty("totalComplaints").GetInt32();
    var openComplaints = stats.GetProperty("openComplaints").GetInt32();
    var resolvedComplaints = stats.GetProperty("resolvedComplaints").GetInt32();
    var wellnessRequests = stats.GetProperty("wellnessRequests").GetInt32();
    var activeAlerts = stats.GetProperty("activeEmergencyAlerts").GetInt32();
    var notificationsSent = stats.GetProperty("notificationsSent").GetInt32();
}

<!-- Welcome Hero -->
<div class="glass-panel p-4 mb-4" style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.9), rgba(15, 23, 42, 0.9)); position: relative; overflow: hidden;">
    <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: var(--ss-accent); filter: blur(100px); opacity: 0.15; border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -50px; right: 100px; width: 150px; height: 150px; background: var(--ss-accent2); filter: blur(80px); opacity: 0.15; border-radius: 50%;"></div>
    
    <div class="position-relative" style="z-index: 1;">
        <h2 class="mb-1 fw-bold">Welcome back, <span class="text-gradient">@userName</span> 👋</h2>
        <p class="text-muted mb-0">Here's a summary of the latest updates and activities on your dashboard.</p>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(233,69,96,0.15);display:flex;align-items:center;justify-content:center;font-size:24px">
                📋
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:var(--ss-text)">@totalComplaints</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Total Complaints</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(245,158,11,0.15);display:flex;align-items:center;justify-content:center;font-size:24px">
                ⚠️
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:#fcd34d">@openComplaints</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Open Complaints</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;font-size:24px">
                ✅
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:#6ee7b7">@resolvedComplaints</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Resolved Complaints</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(168,85,247,0.15);display:flex;align-items:center;justify-content:center;font-size:24px">
                💜
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:var(--ss-accent2)">@wellnessRequests</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Wellness Requests</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow: 0 0 15px rgba(239,68,68,0.2);">
                🚨
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:#fca5a5">@activeAlerts</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Active SOS Alerts</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="glass-card-sm d-flex align-items-center gap-3">
            <div style="width:50px;height:50px;border-radius:14px;background:rgba(59,130,246,0.15);display:flex;align-items:center;justify-content:center;font-size:24px">
                🔔
            </div>
            <div>
                <div style="font-size:26px;font-weight:700;color:#93c5fd">@notificationsSent</div>
                <div style="font-size:13px;color:var(--ss-muted);font-weight:500">Notifications Sent</div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="glass-card h-100 p-4">
            <h5 class="section-title">🗂 Complaints by Category</h5>
            <div class="mt-3">
                <canvas id="complaintsChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card h-100 p-4">
            <h5 class="section-title">💜 Wellness Requests</h5>
            <div class="mt-3">
                <canvas id="wellnessChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card h-100 p-4">
            <h5 class="section-title">🚨 Emergency Alert Status</h5>
            <div class="mt-3">
                <canvas id="emergencyChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="glass-card p-4">
    <h5 class="section-title">⚡ Quick Actions</h5>
    <div class="d-flex flex-wrap gap-3 mt-3">
        @if (role == "Employee" || role == "Manager" || role == "HR" || role == "Admin")
        {
            <a asp-controller="SafeReach" asp-action="Index" class="btn-ss text-decoration-none">
                <i class="bi bi-shield-check me-2"></i>Safe Check-In
            </a>
            <a asp-controller="Wellness" asp-action="Index" class="btn-ss text-decoration-none">
                <i class="bi bi-heart-pulse me-2"></i>Log Mood
            </a>
            <a asp-controller="Complaint" asp-action="Index" class="btn-ss text-decoration-none">
                <i class="bi bi-file-earmark-text me-2"></i>Raise Complaint
            </a>
            <a asp-controller="WFH" asp-action="Index" class="btn-ss text-decoration-none">
                <i class="bi bi-house-door me-2"></i>WFH Request
            </a>
        }
        @if (role == "HR" || role == "Admin")
        {
            <a asp-controller="Complaint" asp-action="All" class="btn-ss text-decoration-none" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);">
                <i class="bi bi-folder2-open me-2"></i>All Complaints
            </a>
        }
        @if (role == "Manager" || role == "Admin")
        {
            <a asp-controller="WFH" asp-action="Approvals" class="btn-ss text-decoration-none" style="background: linear-gradient(135deg, #10b981, #059669);">
                <i class="bi bi-check2-square me-2"></i>WFH Approvals
            </a>
        }
        @if (role == "Security" || role == "Admin")
        {
            <a asp-controller="Emergency" asp-action="All" class="btn-ss text-decoration-none" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                <i class="bi bi-bell-fill me-2"></i>View All Alerts
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Build chart data from server
        const complaintLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    complaints.EnumerateArray().Select(x => x.GetProperty("category").GetString()).ToList()
            ));
        const complaintData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    complaints.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const wellnessLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    wellness.EnumerateArray().Select(x => x.GetProperty("requestType").GetString()).ToList()
            ));
        const wellnessData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    wellness.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const emergencyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    emergency.EnumerateArray().Select(x => x.GetProperty("status").GetString()).ToList()
            ));
        const emergencyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    emergency.EnumerateArray().Select(x => x.GetProperty("count").GetInt32()).ToList()
            ));

        const chartDefaults = {
            plugins: { legend: { labels: { color: '#94a3b8', font: { size: 12 } } } }
        };

        // Complaints Doughnut
        new Chart(document.getElementById('complaintsChart'), {
            type: 'doughnut',
            data: {
                labels: complaintLabels,
                datasets: [{
                    data: complaintData,
                    backgroundColor: ['#e94560','#a855f7','#38bdf8'],
                    borderWidth: 0
                }]
            },
            options: { ...chartDefaults, cutout: '65%' }
        });

        // Wellness Bar
        new Chart(document.getElementById('wellnessChart'), {
            type: 'bar',
            data: {
                labels: wellnessLabels,
                datasets: [{
                    label: 'Requests',
                    data: wellnessData,
                    backgroundColor: ['#a855f7','#e94560'],
                    borderRadius: 6,
                    borderWidth: 0
                }]
            },
            options: {
                ...chartDefaults,
                scales: {
                    x: { ticks: { color: '#94a3b8' }, grid: { color: '#2d3748' } },
                    y: { ticks: { color: '#94a3b8' }, grid: { color: '#2d3748' } }
                }
            }
        });

        // Emergency Pie
        new Chart(document.getElementById('emergencyChart'), {
            type: 'pie',
            data: {
                labels: emergencyLabels,
                datasets: [{
                    data: emergencyData,
                    backgroundColor: ['#e94560','#34d399'],
                    borderWidth: 0
                }]
            },
            options: { ...chartDefaults }
        });
    </script>
}