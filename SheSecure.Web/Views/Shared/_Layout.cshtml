<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SheSecure</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var role = Context.Session.GetString("Role") ?? "";
        var userName = Context.Session.GetString("UserName") ?? "User";
        var initials = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
        var isLoggedIn = Context.Session.GetString("Token") != null;
    }

    @if (isLoggedIn)
    {
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-brand">
                <div class="logo-icon">🛡️</div>
                <span>SheSecure</span>
            </div>

            <div class="sidebar-nav mt-2">
                <!-- All roles -->
                <div class="nav-section">Main</div>
                <a asp-controller="Dashboard" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <!-- Employee & above -->
                @if (role == "Employee" || role == "Manager" || role == "HR" || role == "Admin")
                {
                    <div class="nav-section">Safety</div>
                    <a asp-controller="SafeReach" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "SafeReach" ? "active" : "")">
                        <i class="bi bi-shield-check"></i> Safe Check-In
                    </a>
                    <a asp-controller="Emergency" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" ? "active" : "")">
                        <i class="bi bi-exclamation-octagon"></i> SOS / Emergency
                    </a>

                    <div class="nav-section">Wellness</div>
                    <a asp-controller="Wellness" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Wellness" ? "active" : "")">
                        <i class="bi bi-heart-pulse"></i> Mood & Wellness
                    </a>
                    <a asp-controller="WFH" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "WFH" ? "active" : "")">
                        <i class="bi bi-house-door"></i> WFH Requests
                    </a>

                    <div class="nav-section">Complaints</div>
                    <a asp-controller="Complaint" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" ? "active" : "")">
                        <i class="bi bi-file-earmark-text"></i> My Complaints
                    </a>
                }

                <!-- HR / POSH -->
                @if (role == "HR" || role == "Admin")
                {
                    <div class="nav-section">HR / POSH</div>
                    <a asp-controller="Complaint" asp-action="All"
                           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-folder2-open"></i> All Complaints
                    </a>
                }

                <!-- Manager -->
                @if (role == "Manager" || role == "Admin")
                {
                    <div class="nav-section">Manager</div>
                    <a asp-controller="WFH" asp-action="Approvals"
                           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Approvals" ? "active" : "")">
                        <i class="bi bi-check2-square"></i> WFH Approvals
                    </a>
                }

                <!-- Security -->
                @if (role == "Security" || role == "Admin")
                {
                    <div class="nav-section">Security</div>
                    <a asp-controller="Emergency" asp-action="All"
                           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-bell-fill"></i> All Alerts
                    </a>
                }

                <!-- Notifications — all roles -->
                <div class="nav-section">Account</div>
                <a asp-controller="Notification" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
                    <i class="bi bi-bell"></i> Notifications
                </a>
            </div>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="user-avatar">@initials</div>
                    <div>
                        <div style="font-size:14px;font-weight:600;color:var(--ss-text)">@userName</div>
                        <div class="status-chip neutral mt-1" style="font-size:10px;padding:2px 6px;">@role</div>
                    </div>
                </div>
                <a asp-controller="Auth" asp-action="Logout" class="btn-ss-outline w-100 text-center d-block" style="text-decoration:none;">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </nav>

        <!-- Main -->
        <div id="main-content">
            <div id="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-right">
                    <button class="sos-btn" onclick="triggerSOS()" title="Emergency SOS">SOS</button>
                    <a asp-controller="Notification" asp-action="Index" style="text-decoration:none">
                        <button class="notif-btn">
                            <i class="bi bi-bell"></i>
                            <span class="notif-badge" id="notifCount" style="display:none">0</span>
                        </button>
                    </a>
                    <div class="user-pill">
                        <div class="user-avatar">@initials</div>
                        <span class="ms-1 me-2">@userName</span>
                    </div>
                </div>
            </div>
            <div class="page-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        function triggerSOS() {
            if (confirm('🚨 Trigger Emergency SOS Alert?')) {
                fetch('/Emergency/SOS', { method: 'POST' })
                .then(() => alert('SOS alert sent. Help is on the way.'))
                .catch(() => alert('Could not send SOS. Please call security directly.'));
            }
        }

        function fetchNotifCount() {
            fetch('/Notification/UnreadCount')
                .then(r => r.json())
                .then(data => {
                    const badge = document.getElementById('notifCount');
                    if (badge) {
                        if (data.count > 0) {
                            badge.textContent = data.count;
                            badge.style.display = 'flex';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                })
                .catch(() => {});
        }

        // Run on load and poll every 15 seconds
        document.addEventListener("DOMContentLoaded", function () {
            if (document.getElementById('notifCount')) {
                fetchNotifCount();
                setInterval(fetchNotifCount, 15000);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>