<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SheSecure</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    
    <!-- Accessibility CSS Overrides -->
    <style>
        /* Accessibility: High Contrast Mode */
        body.high-contrast-mode {
            --ss-bg: #000000 !important;
            --ss-panel: #000000 !important;
            --ss-text: #ffffff !important;
            --ss-muted: #e2e8f0 !important;
            --ss-primary: #ffff00 !important;
            --ss-danger: #ff0000 !important;
            --ss-success: #00ff00 !important;
            --ss-info: #00ffff !important;
            background-color: #000000 !important;
            color: #ffffff !important;
        }
        body.high-contrast-mode .glass-card, 
        body.high-contrast-mode .sidebar,
        body.high-contrast-mode #sidebar {
            background: #000000 !important;
            border: 2px solid #ffff00 !important;
            box-shadow: none !important;
        }
        body.high-contrast-mode a, 
        body.high-contrast-mode button,
        body.high-contrast-mode .nav-item,
        body.high-contrast-mode i {
            color: #ffff00 !important;
        }
        body.high-contrast-mode .section-title {
            color: #ffff00 !important;
            border-bottom: 2px solid #ffff00 !important;
        }

        /* Accessibility: Large Text Mode */
        body.large-text-mode {
            zoom: 1.15;
            -moz-transform: scale(1.15);
            -moz-transform-origin: top center;
        }
    </style>
</head>
<body>

    @{
        var role = Context.Session.GetString("Role") ?? "";
        var userName = Context.Session.GetString("UserName") ?? "User";
        var initials = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
        var isLoggedIn = Context.Session.GetString("Token") != null;
        var managerMode = Context.Session.GetString("ManagerMode");
        bool hideSidebar = ViewBag.HideSidebar == true;
    }

    @if (isLoggedIn)
    {
        @if (!hideSidebar)
        {
        <!-- Sidebar -->
        <nav id="sidebar">
            <button id="sidebarToggle" class="btn btn-sm text-white d-none d-md-flex align-items-center justify-content-center" style="position: absolute; right: -15px; top: 30px; background: var(--ss-card); border: 1px solid var(--ss-border); border-radius: 50%; width: 30px; height: 30px; z-index: 100; box-shadow: 0 4px 6px rgba(0,0,0,0.3); transition: all 0.3s ease;">
                <i class="bi bi-chevron-left" style="font-size: 14px;"></i>
            </button>

            <div class="sidebar-brand">
                <div class="logo-icon" style="transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);"><i class="bi bi-shield-shaded"></i></div>
                <span class="sidebar-brand-text">SheSecure</span>
            </div>

            <div class="sidebar-nav mt-2">
                <!-- All roles (except Security and Admin) -->
                @if (role != "Security" && role != "Admin")
                {
                    <div class="nav-section sidebar-text">Main</div>
                    <a asp-controller="Dashboard" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> <span class="sidebar-text">Dashboard</span>
                    </a>
                }

                <!-- Employee & above (Personal Features) -->
                @if (role == "Employee" || (role == "HR" && Context.Session.GetString("HRMode") == "Personal") || (role == "Manager" && managerMode == "Personal"))
                {
                    <div class="nav-section sidebar-text">Safety</div>
                    <a asp-controller="SafeReach" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SafeReach" ? "active" : "")">
                        <i class="bi bi-shield-check"></i> <span class="sidebar-text">Safe Check-In</span>
                    </a>
                    <a asp-controller="Emergency" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" ? "active" : "")">
                        <i class="bi bi-exclamation-octagon"></i> <span class="sidebar-text">SOS / Emergency</span>
                    </a>

                    <div class="nav-section sidebar-text">Wellness</div>
                    <a asp-controller="Wellness" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Wellness" ? "active" : "")">
                        <i class="bi bi-heart-pulse"></i> <span class="sidebar-text">Mood & Wellness</span>
                    </a>
                    <a asp-controller="WFH" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WFH" ? "active" : "")">
                        <i class="bi bi-house-door"></i> <span class="sidebar-text">Wellness Requests</span>
                    </a>

                    <div class="nav-section sidebar-text">Resources & Complaints</div>
                    <a asp-controller="Complaint" asp-action="Index"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" ? "active" : "")">
                        <i class="bi bi-file-earmark-text"></i> <span class="sidebar-text">My Complaints</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="LearningHub"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LearningHub" ? "active" : "")">
                        <i class="bi bi-mortarboard-fill"></i> <span class="sidebar-text">Safety & Rights</span>
                    </a>
                }

                <!-- HR / POSH -->
                @if (role == "HR" && Context.Session.GetString("HRMode") == "Administration")
                {
                    <div class="nav-section sidebar-text">HR Administration</div>
                    <a asp-controller="Complaint" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-folder2-open"></i> <span class="sidebar-text">All Complaints</span>
                    </a>
                    <a asp-controller="SafeReach" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SafeReach" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> <span class="sidebar-text">All Safe Check-Ins</span>
                    </a>
                }

                <!-- Manager -->
                @if (role == "Manager" && managerMode == "Leadership")
                {
                    <div class="nav-section sidebar-text">Manager</div>
                    <a asp-controller="Manager" asp-action="SafeChecks"
                        class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "SafeChecks" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> <span class="sidebar-text">Team Safe Checks</span>
                    </a>
                    <a asp-controller="WFH" asp-action="Approvals"
                        class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WFH" && ViewContext.RouteData.Values["action"]?.ToString() == "Approvals" ? "active" : "")">
                        <i class="bi bi-check2-square"></i> <span class="sidebar-text">Wellness Approvals</span>
                    </a>
                    <a asp-controller="Manager" asp-action="Directory"
                        class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Directory" ? "active" : "")">
                        <i class="bi bi-people"></i> <span class="sidebar-text">Team Directory</span>
                    </a>
                }

                <!-- Security -->
                @if (role == "Security")
                {
                    <div class="nav-section sidebar-text">Security</div>
                    
                    <a asp-controller="Emergency" asp-action="Tracking"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Tracking" ? "active" : "")">
                        <i class="bi bi-geo-alt-fill"></i> <span class="sidebar-text">Active Tracking</span>
                    </a>
                    
                    <a asp-controller="Emergency" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-bell-fill"></i> <span class="sidebar-text">SOS Alerts</span>
                    </a>

                    <a asp-controller="Emergency" asp-action="Escalations"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Escalations" ? "active" : "")">
                        <i class="bi bi-shield-exclamation"></i> <span class="sidebar-text">Escalations</span>
                    </a>

                    <a asp-controller="Emergency" asp-action="Directory"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Directory" ? "active" : "")">
                        <i class="bi bi-journal-medical"></i> <span class="sidebar-text">Emergency Directory</span>
                    </a>
                }

                <!-- System Admin Oversight -->
                @if (role == "Admin")
                {
                    <div class="nav-section sidebar-text">System Oversight</div>
                    
                    <a asp-controller="Admin" asp-action="Users"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                        <i class="bi bi-people-fill"></i> <span class="sidebar-text">User Management</span>
                    </a>

                    <a asp-controller="Admin" asp-action="Settings"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")">
                        <i class="bi bi-sliders"></i> <span class="sidebar-text">System Settings</span>
                    </a>

                    <a asp-controller="Admin" asp-action="AuditLogs"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")">
                        <i class="bi bi-shield-check"></i> <span class="sidebar-text">Audit Logs</span>
                    </a>
                    
                    <a asp-controller="Complaint" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-folder2-open"></i> <span class="sidebar-text">All Complaints</span>
                    </a>
                    <a asp-controller="SafeReach" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SafeReach" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> <span class="sidebar-text">All Safe Check-Ins</span>
                    </a>
                    <a asp-controller="WFH" asp-action="Approvals"
                        class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WFH" && ViewContext.RouteData.Values["action"]?.ToString() == "Approvals" ? "active" : "")">
                        <i class="bi bi-check2-square"></i> <span class="sidebar-text">Wellness Approvals</span>
                    </a>
                    <a asp-controller="Emergency" asp-action="Tracking"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Tracking" ? "active" : "")">
                        <i class="bi bi-geo-alt-fill"></i> <span class="sidebar-text">Active Tracking</span>
                    </a>
                    <a asp-controller="Emergency" asp-action="All"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "All" ? "active" : "")">
                        <i class="bi bi-bell-fill"></i> <span class="sidebar-text">SOS Alerts</span>
                    </a>
                    <a asp-controller="Emergency" asp-action="Escalations"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Escalations" ? "active" : "")">
                        <i class="bi bi-shield-exclamation"></i> <span class="sidebar-text">Escalations</span>
                    </a>
                    <a asp-controller="Emergency" asp-action="Directory"
                           class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emergency" && ViewContext.RouteData.Values["action"]?.ToString() == "Directory" ? "active" : "")">
                        <i class="bi bi-journal-medical"></i> <span class="sidebar-text">Emergency Directory</span>
                    </a>
                }

                <!-- Notifications — all roles -->
                <div class="nav-section sidebar-text">Account</div>
                <a asp-controller="Notification" asp-action="Index"
                       class="nav-item nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
                    <i class="bi bi-bell"></i> <span class="sidebar-text">Notifications</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-3 mb-3 sidebar-text">
                    <div class="user-avatar flex-shrink-0">@initials</div>
                    <div class="sidebar-text">
                        <div style="font-size:14px;font-weight:600;color:var(--ss-text)">@userName</div>
                        <div class="status-chip neutral mt-1" style="font-size:10px;padding:2px 6px;">@role</div>
                    </div>
                </div>
                
                @if (role == "Manager")
                {
                    <form method="post" asp-action="SetMode" asp-controller="Manager" class="mb-2 w-100">
                        <input type="hidden" name="mode" value="@(managerMode == "Personal" ? "Leadership" : "Personal")" />
                        <button type="submit" class="btn btn-outline-info w-100 text-center" style="font-size: 13px; border-radius: 8px;">
                            <i class="bi bi-arrow-left-right me-1"></i> Switch to @(managerMode == "Personal" ? "Leadership" : "Personal")
                        </button>
                    </form>
                }
                
                @if (role == "HR")
                {
                    var hrMode = Context.Session.GetString("HRMode");
                    <form method="post" asp-action="SetMode" asp-controller="HR" class="mb-2 w-100">
                        <input type="hidden" name="mode" value="@(hrMode == "Personal" ? "Administration" : "Personal")" />
                        <button type="submit" class="btn btn-outline-warning w-100 text-center" style="font-size: 13px; border-radius: 8px;">
                            <i class="bi bi-arrow-left-right me-1"></i> Switch to @(hrMode == "Personal" ? "Administration" : "Personal")
                        </button>
                    </form>
                }
                
                <a asp-controller="Auth" asp-action="Logout" class="btn-ss-outline w-100 text-center d-block nav-item nav-link" style="text-decoration:none;">
                    <i class="bi bi-box-arrow-right"></i> <span class="sidebar-text">Logout</span>
                </a>
            </div>
        </nav>
        }

        <!-- Main -->
        <div id="main-content" style="@(hideSidebar ? "margin-left: 0; width: 100%;" : "")">
            <div id="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-right">
                    <!-- Accessibility Features -->
                    <button class="notif-btn hover-lift me-1" onclick="toggleHighContrast()" title="Toggle High Contrast Mode">
                        <i class="bi bi-circle-half"></i>
                    </button>
                    <button class="notif-btn hover-lift me-2" onclick="toggleLargeText()" title="Toggle Large Text Mode">
                        <i class="bi bi-fonts"></i>
                    </button>

                    @if (role != "Security" && role != "Admin")
                    {
                        <button class="sos-btn hover-lift" onclick="triggerSOS()" title="Emergency SOS" style="position: relative;">
                            <span style="position:absolute; inset:-2px; border-radius:50%; border:2px solid rgba(239,68,68,0.5); animation: pulse-ring 1.5s infinite;"></span>
                            SOS
                        </button>
                    }
                    <a asp-controller="Notification" asp-action="Index" style="text-decoration:none">
                        <button class="notif-btn hover-lift">
                            <i class="bi bi-bell"></i>
                            <span class="notif-badge" id="notifCount" style="display:none">0</span>
                        </button>
                    </a>
                    <div class="user-pill hover-lift">
                        <div class="user-avatar">@initials</div>
                        <span class="ms-1 me-2">@userName</span>
                    </div>
                </div>
            </div>
            <div class="page-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

        @if (!hideSidebar)
        {
        <!-- Mobile Bottom Nav -->
        <div class="mobile-bottom-nav">
            <a asp-controller="Dashboard" asp-action="Index" class="mobile-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                <span>Home</span>
            </a>
            <a asp-controller="Wellness" asp-action="Index" class="mobile-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Wellness" ? "active" : "")">
                <i class="bi bi-heart-pulse"></i>
                <span>Wellness</span>
            </a>
            
            <!-- Center FAB -->
            @if (role != "Security" && role != "Admin")
            {
                <div style="position: relative; width: 56px; height: 56px;">
                    <div class="mobile-fab-container">
                        <button class="mobile-fab" onclick="triggerSOS()">
                            🚨
                        </button>
                    </div>
                </div>
            }

            <a asp-controller="Complaint" asp-action="Index" class="mobile-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" ? "active" : "")">
                <i class="bi bi-file-earmark-text"></i>
                <span>Reports</span>
            </a>
            <a asp-controller="Notification" asp-action="Index" class="mobile-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
                <i class="bi bi-bell"></i>
                <span>Alerts</span>
            </a>
        </div>
        }

    <!-- Global Direct SOS Confirmation Overlay -->
    <div id="globalSosConfirmOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 999999; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(8px); flex-direction: column; align-items: center; justify-content: center; padding: 20px;">
        <div class="glass-card text-center" style="max-width: 400px; border: 2px solid rgba(239, 68, 68, 0.5); background: rgba(30, 41, 59, 0.95); box-shadow: 0 0 40px rgba(239, 68, 68, 0.3); border-radius: 16px;">
            <i class="bi bi-exclamation-octagon-fill text-danger mb-3 d-inline-block" style="font-size: 3rem; animation: pulse-sos 1s infinite;"></i>
            <h4 class="text-white fw-bold mb-2">Trigger Emergency SOS?</h4>
            <p class="text-muted mb-4" style="font-size: 14px;">This will immediately alert the security response team. Are you sure you are in danger?</p>
            
            <form method="post" action="/Emergency/SOS" id="globalSosForm" class="d-none">
                <input type="hidden" name="location" id="sosLocationInput" value="Global Panic Button (Location Unavailable)">
                <input type="hidden" name="description" value="GLOBAL QUICK PANIC TRIGGER. Immediate response required.">
                <input type="hidden" name="severity" value="Critical">
            </form>

            <div class="d-flex gap-3 justify-content-center">
                <button type="button" onclick="cancelGlobalSosConfirm()" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</button>
                <button type="button" onclick="executeGlobalSOS()" id="globalSosConfirmBtn" class="btn btn-danger px-4 py-2 fw-bold" style="border-radius: 8px; box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);">Yes, Send Help</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Sidebar Toggle Logic
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('sidebar-collapsed');
            document.getElementById('main-content').classList.toggle('main-content-expanded');
            const icon = this.querySelector('i');
            if (icon.classList.contains('bi-chevron-left')) {
                icon.classList.replace('bi-chevron-left', 'bi-chevron-right');
            } else {
                icon.classList.replace('bi-chevron-right', 'bi-chevron-left');
            }
        });

        function triggerSOS() {
            document.getElementById('globalSosConfirmOverlay').style.display = 'flex';
        }

        function cancelGlobalSosConfirm() {
            document.getElementById('globalSosConfirmOverlay').style.display = 'none';
        }

        function executeGlobalSOS() {
            let btn = document.getElementById('globalSosConfirmBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="width: 1.5rem; height: 1.5rem;"></span>';
            btn.disabled = true;

            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function (position) {
                    let lat = position.coords.latitude.toFixed(6);
                    let lng = position.coords.longitude.toFixed(6);
                    document.getElementById('sosLocationInput').value = `GPS Coordinates: ${lat}, ${lng} (Map Link: https://www.google.com/maps?q=${lat},${lng})`;
                    document.getElementById('globalSosForm').submit();
                }, function (error) {
                    document.getElementById('globalSosForm').submit(); // Submit anyway if GPS fails
                });
            } else {
                document.getElementById('globalSosForm').submit();
            }
        }

        // --- Accessibility Features ---
        function toggleHighContrast() {
            document.body.classList.toggle('high-contrast-mode');
            const isHc = document.body.classList.contains('high-contrast-mode');
            localStorage.setItem('ss_high_contrast', isHc);
        }

        function toggleLargeText() {
            document.body.classList.toggle('large-text-mode');
            const isLt = document.body.classList.contains('large-text-mode');
            localStorage.setItem('ss_large_text', isLt);
        }

        // Restore settings on load
        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('ss_high_contrast') === 'true') {
                document.body.classList.add('high-contrast-mode');
            }
            if (localStorage.getItem('ss_large_text') === 'true') {
                document.body.classList.add('large-text-mode');
            }
        });

        function fetchNotifCount() {
            fetch('/Notification/UnreadCount')
                .then(r => r.json())
                .then(data => {
                    const badge = document.getElementById('notifCount');
                    if (badge) {
                        if (data.count > 0) {
                            badge.textContent = data.count;
                            badge.style.display = 'flex';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                })
                .catch(() => {});
        }

        // Run on load and poll every 15 seconds
        document.addEventListener("DOMContentLoaded", function () {
            if (document.getElementById('notifCount')) {
                fetchNotifCount();
                setInterval(fetchNotifCount, 15000);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
