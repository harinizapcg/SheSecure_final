@{
    ViewData["Title"] = "Safe Check-In";
    var records = (System.Text.Json.JsonElement)ViewBag.Records;
    var role = Context.Session.GetString("Role") ?? "";
}

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="row g-4">
    <!-- Create Check-In Form -->
    <div class="col-md-4">
        <div class="glass-card mb-4">
            <h5 class="section-title">🛡 New Safe Check-In</h5>
            <form method="post" asp-action="Create" class="mt-4">
                <div class="mb-4">
                    <label class="form-label">Expected Arrival Time</label>
                    <input type="datetime-local" name="expectedArrivalTime" class="form-control" required />
                </div>
                <button type="submit" class="btn-ss w-100 py-2">
                    <i class="bi bi-shield-check me-2"></i>Submit Check-In
                </button>
            </form>
        </div>

        <!-- Info Card -->
        <div class="glass-card-sm border-start border-4 border-info" style="border-radius: 8px;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-info-circle text-info"></i>
                <span class="fw-medium text-white" style="font-size: 14px;">How it works</span>
            </div>
            <div style="font-size: 13px; color: var(--ss-muted); line-height: 1.6;">
                <ol class="ps-3 mb-0">
                    <li class="mb-1">Submit your expected arrival time</li>
                    <li class="mb-1">Acknowledge when you arrive safely</li>
                    <li>If missed, manager gets notified automatically</li>
                </ol>
            </div>
        </div>
    </div>

    <!-- Records Table -->
    <div class="col-md-8">
        <div class="glass-card h-100">
            <h5 class="section-title">📋 Check-In Records</h5>

            @if (!records.EnumerateArray().Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">🛡</div>
                    <h5>No check-ins yet</h5>
                    <p>Start a safe check-in when traveling late or to remote areas.</p>
                </div>
            }
            else
            {
                <div class="table-responsive mt-3">
                    <table class="table-glass table border-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Employee ID</th>
                                <th>Expected Arrival</th>
                                <th>Status</th>
                                <th>Acknowledged At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in records.EnumerateArray())
                            {
                                var id = r.GetProperty("id").GetInt32();
                                var empId = r.GetProperty("employeeId").GetString();
                                var expectedTime = r.GetProperty("expectedArrivalTime").GetString();
                                var status = r.GetProperty("status").GetString();
                                var isAcknowledged = r.GetProperty("isAcknowledged").GetBoolean();
                                var acknowledgedAt = r.TryGetProperty("acknowledgedAt", out var ackProp)
                                                     && ackProp.ValueKind != System.Text.Json.JsonValueKind.Null
                                                     ? ackProp.GetString() : null;

                                var statusClass = status == "Reached Safely" ? "success"
                                               : status == "Pending" ? "warning"
                                               : "error";

                                <tr>
                                    <td class="text-muted">#@id</td>
                                    <td class="fw-medium">@empId</td>
                                    <td style="font-size: 13px; color: var(--ss-text);">@DateTime.Parse(expectedTime!).ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>
                                        <span class="status-chip @statusClass">@status</span>
                                    </td>
                                    <td style="color: var(--ss-muted); font-size: 13px;">
                                        @(acknowledgedAt != null
                                            ? DateTime.Parse(acknowledgedAt).ToString("dd MMM, hh:mm tt")
                                            : "—")
                                    </td>
                                    <td>
                                        @if (!isAcknowledged)
                                        {
                                            <div class="d-flex gap-2">
                                                <form method="post" asp-action="Acknowledge" class="m-0">
                                                    <input type="hidden" name="safeReachId" value="@id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success border-0" style="background: rgba(16,185,129,0.1); border-radius: 6px;">
                                                        <i class="bi bi-check2-all me-1"></i>Ack
                                                    </button>
                                                </form>

                                                @if (role == "Manager" || role == "Security" || role == "Admin")
                                                {
                                                    <form method="post" asp-action="Escalate" class="m-0">
                                                        <input type="hidden" name="id" value="@id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0" style="background: rgba(233,69,96,0.1); border-radius: 6px;">
                                                            <i class="bi bi-exclamation-triangle me-1"></i>Escalate
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="font-size: 13px; color: #34d399;"><i class="bi bi-check2"></i> Done</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
