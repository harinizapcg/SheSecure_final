@{
    ViewData["Title"] = "All Safe Check-Ins";
    var records = (System.Text.Json.JsonElement)ViewBag.Records;
    var role = Context.Session.GetString("Role") ?? "";
}

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4 fade-in-up">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4 fade-in-up">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card h-100 fade-in-up">
    <h5 class="section-title">📋 All Active and Past Check-Ins</h5>

    @if (!records.EnumerateArray().Any())
    {
        <div class="empty-state py-5">
            <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 24px; opacity: 0.5;">🛡️</div>
            <h5 class="text-white fw-bold">No check-ins yet</h5>
            <p class="text-muted" style="max-width: 300px; margin: 0 auto;">There are currently no safe check-ins to display.</p>
        </div>
    }
    else
    {
        <style>
            .safe-card {
                background: rgba(30, 41, 59, 0.4);
                border: 1px solid rgba(255,255,255,0.05);
                border-left: 4px solid var(--ss-muted);
                border-radius: 12px;
                padding: 20px 24px;
                margin-bottom: 16px;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
            .safe-card:hover {
                background: rgba(30, 41, 59, 0.7);
                transform: translateY(-2px);
                border-color: rgba(255,255,255,0.1);
                box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            }
            .safe-card.pending {
                border-left-color: #f59e0b;
            }
            .safe-card.reached {
                border-left-color: #10b981;
            }
            .safe-card.escalated {
                border-left-color: #ef4444;
            }
            
            .safe-card-time {
                display: flex;
                align-items: center;
                gap: 16px;
            }
            .safe-card-time-block {
                display: flex;
                flex-direction: column;
            }
            .safe-card-time-label {
                font-size: 10px;
                color: var(--ss-muted);
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 4px;
                font-weight: 600;
            }
            .safe-card-time-value {
                font-size: 14px;
                color: rgba(255,255,255,0.9);
                font-weight: 500;
            }
        </style>

        <div class="mt-4">
            @foreach (var r in records.EnumerateArray())
            {
                var id = r.GetProperty("id").GetInt32();
                var empId = r.GetProperty("employeeId").GetString();
                var expectedTime = r.GetProperty("expectedArrivalTime").GetString();
                var status = r.GetProperty("status").GetString();
                var isAcknowledged = r.GetProperty("isAcknowledged").GetBoolean();
                var acknowledgedAt = r.TryGetProperty("acknowledgedAt", out var ackProp)
                                     && ackProp.ValueKind != System.Text.Json.JsonValueKind.Null
                                     ? ackProp.GetString() : null;

                var statusClass = status == "Reached Safely" ? "success"
                               : status == "Pending" ? "warning"
                               : "error";
                               
                var cardClass = status == "Reached Safely" ? "reached"
                               : status == "Pending" ? "pending"
                               : "escalated";

                <div class="safe-card @cardClass fade-in-up">
                    <div class="d-flex align-items-center gap-4">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-size: 20px; color: rgba(255,255,255,0.7);">
                            <i class="bi @(isAcknowledged ? "bi-check-circle-fill text-success" : status == "Pending" ? "bi-clock-history text-warning" : "bi-exclamation-triangle-fill text-danger")"></i>
                        </div>
                        
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;"><i class="bi bi-person me-1"></i>Emp: @empId</span>
                                <span class="status-chip @statusClass px-2 py-0 d-flex align-items-center gap-1" style="font-size: 10px;">
                                    @if(status == "Pending") { <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;animation:pulse-sos 1s infinite;"></span> }
                                    @status
                                </span>
                            </div>
                            
                            <div class="safe-card-time">
                                <div class="safe-card-time-block">
                                    <span class="safe-card-time-label">Expected Arrival</span>
                                    <span class="safe-card-time-value"><i class="bi bi-geo-alt me-1 text-muted"></i>@TimeHelper.ToIST(expectedTime!).ToString("dd MMM, hh:mm tt")</span>
                                </div>
                                
                                <i class="bi bi-arrow-right" style="color: rgba(255,255,255,0.2);"></i>
                                
                                <div class="safe-card-time-block">
                                    <span class="safe-card-time-label">Actual Arrival</span>
                                    <span class="safe-card-time-value" style="color: @(isAcknowledged ? "#10b981" : "var(--ss-muted)")">
                                        @if(isAcknowledged && acknowledgedAt != null) {
                                            <i class="bi bi-check2-circle me-1"></i>@TimeHelper.ToIST(acknowledgedAt).ToString("dd MMM, hh:mm tt")
                                        } else {
                                            <span>—</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div>
                        @if (!isAcknowledged)
                        {
                            @if (role == "Manager" || role == "Security" || role == "Admin")
                            {
                                <form method="post" asp-controller="SafeReach" asp-action="Escalate" class="m-0">
                                    <input type="hidden" name="id" value="@id" />
                                    <button type="submit" class="btn btn-sm ripple text-danger" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 8px 16px; font-weight: 600;">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>Escalate
                                    </button>
                                </form>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
