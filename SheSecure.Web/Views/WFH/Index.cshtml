@{
    ViewData["Title"] = "Wellness Requests";
    var requests = (System.Text.Json.JsonElement)ViewBag.Requests;
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="row g-4">
    <!-- Request Form -->
    <div class="col-md-4">
        <div class="glass-card mb-4">
            <h5 class="section-title">🏠 New Wellness Request</h5>
            <form method="post" asp-action="Create" class="mt-4">
                <div class="mb-3">
                    <label class="form-label">Request Type</label>
                    <select name="requestType" class="form-select" required>
                        <option value="" disabled selected>Select type</option>
                        <option value="WFH">Work From Home</option>
                        <option value="Counselling">Counselling</option>
                        <option value="MentalHealthLeave">Mental Health Leave</option>
                        <option value="FlexiHours">Flexi Hours</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Request Date</label>
                    <input type="date" name="requestDate" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Priority</label>
                    <select name="priority" class="form-select" required>
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label">Description</label>
                    <textarea name="description" rows="4" class="form-control" placeholder="Briefly describe your reason..." required style="resize: none;"></textarea>
                    <div class="mt-2" style="font-size: 12px; color: var(--ss-muted);">
                        <i class="bi bi-shield-lock text-gradient me-1"></i>
                        Your reason is privacy-protected and visible only to your manager.
                    </div>
                </div>
                <button type="submit" class="btn-ss w-100 py-2">
                    <i class="bi bi-send me-2"></i>Submit Request
                </button>
            </form>
        </div>
    </div>

    <!-- My Requests Table -->
    <div class="col-md-8">
        <div class="glass-card h-100">
            <h5 class="section-title">📋 My Wellness Requests</h5>

            @if (!requests.EnumerateArray().Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">🏠</div>
                    <h5>No requests yet</h5>
                    <p>You haven't submitted any Wellness or Flexi requests.</p>
                </div>
            }
            else
            {
                <style>
                    .wfh-card {
                        background: rgba(30, 41, 59, 0.4);
                        border: 1px solid rgba(255,255,255,0.05);
                        border-radius: 12px;
                        padding: 20px;
                        margin-bottom: 16px;
                        transition: all 0.3s ease;
                        border-left: 4px solid var(--ss-muted);
                    }
                    .wfh-card:hover {
                        background: rgba(30, 41, 59, 0.7);
                        border-color: rgba(255,255,255,0.1);
                        transform: translateY(-2px);
                        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
                    }
                    .wfh-card.approved { border-left-color: #10b981; }
                    .wfh-card.rejected { border-left-color: #ef4444; }
                    .wfh-card.pending { border-left-color: #f59e0b; }
                </style>
                <div class="mt-3">
                    @foreach (var r in requests.EnumerateArray())
                    {
                        var id = r.GetProperty("id").GetInt32();
                        var reqType = r.GetProperty("requestType").GetString();
                        var desc = r.GetProperty("description").GetString();
                        var priority = r.GetProperty("priority").GetString();
                        var status = r.GetProperty("status").GetString();
                        var createdAt = r.GetProperty("createdAt").GetString();
                        var requestDate = r.TryGetProperty("requestDate", out var rd) ? rd.GetString() : null;

                        var statusClass = status == "Approved" ? "success"
                                       : status == "Rejected" ? "error"
                                       : "warning";
                        
                        var cardClass = status == "Approved" ? "approved"
                                       : status == "Rejected" ? "rejected"
                                       : "pending";

                        var priorityClass = priority == "High" ? "error"
                                         : priority == "Medium" ? "warning"
                                         : "success";

                        <div class="wfh-card @cardClass fade-in-up">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                        <span class="status-chip @priorityClass px-2 py-0" style="font-size: 10px;">@priority Priority</span>
                                    </div>
                                    <h6 class="text-white fw-bold m-0 d-flex align-items-center gap-2">
                                        <i class="bi @(reqType == "WFH" ? "bi-house-laptop text-info" : reqType == "Counselling" ? "bi-heart-pulse text-danger" : reqType == "FlexiHours" ? "bi-clock-history text-warning" : "bi-bandaid text-success")"></i>
                                        @reqType
                                    </h6>
                                </div>
                                <span class="status-chip @statusClass fw-bold px-3 py-1" style="border-radius: 8px;">
                                    @status
                                </span>
                            </div>
                            
                            <p class="mt-3 mb-3 text-white opacity-75" style="font-size: 13px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 8px; line-height: 1.5;">
                                @desc
                            </p>
                            
                            <div class="d-flex align-items-center text-muted" style="font-size: 12px;">
                                <i class="bi bi-calendar-event me-2"></i>
                                @if (!string.IsNullOrEmpty(requestDate))
                                {
                                    <span>For: @(DateTime.TryParse(requestDate, out var parsedDate) ? parsedDate.ToString("dd MMM yyyy") : requestDate) | </span>
                                }
                                Submitted on @TimeHelper.ToIST(createdAt!).ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

