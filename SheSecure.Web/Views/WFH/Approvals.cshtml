@{
    ViewData["Title"] = "WFH Approvals";
    var requests = (System.Text.Json.JsonElement)ViewBag.Requests;
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card">
    <h5 class="section-title">✅ Pending WFH Approvals</h5>

    @if (!requests.EnumerateArray().Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h5>All caught up</h5>
            <p>No pending WFH requests to review.</p>
        </div>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table-glass table border-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Employee ID</th>
                        <th>Type</th>
                        <th>Priority</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in requests.EnumerateArray())
                    {
                        var id = r.GetProperty("id").GetInt32();
                        var empId = r.GetProperty("employeeId").GetString();
                        var reqType = r.GetProperty("requestType").GetString();
                        var desc = r.GetProperty("description").GetString();
                        var priority = r.GetProperty("priority").GetString();
                        var status = r.GetProperty("status").GetString();
                        var createdAt = r.GetProperty("createdAt").GetString();

                        var statusClass = status == "Approved" ? "success"
                                       : status == "Rejected" ? "error"
                                       : "warning";
                                       
                        var priorityClass = priority == "High" ? "error"
                                         : priority == "Medium" ? "warning"
                                         : "success";

                        <tr>
                            <td class="text-muted">#@id</td>
                            <td class="fw-medium text-white">@empId</td>
                            <td>@reqType</td>
                            <td><span class="status-chip @priorityClass">@priority</span></td>
                            <td style="color: var(--ss-muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @desc
                            </td>
                            <td><span class="status-chip @statusClass">@status</span></td>
                            <td style="color: var(--ss-muted); font-size: 13px;">
                                @DateTime.Parse(createdAt!).ToString("dd MMM yyyy")
                            </td>
                            <td>
                                @if (status == "Pending")
                                {
                                    <div class="d-flex gap-2">
                                        <form method="post" asp-action="UpdateStatus" class="m-0">
                                            <input type="hidden" name="requestId" value="@id" />
                                            <input type="hidden" name="status" value="Approved" />
                                            <button type="submit" class="btn btn-sm btn-outline-success border-0" style="background: rgba(16,185,129,0.1); border-radius: 6px;">
                                                <i class="bi bi-check2"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="UpdateStatus" class="m-0">
                                            <input type="hidden" name="requestId" value="@id" />
                                            <input type="hidden" name="status" value="Rejected" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0" style="background: rgba(233,69,96,0.1); border-radius: 6px;">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
