@{
    ViewData["Title"] = "WFH Approvals";
    var requests = (System.Text.Json.JsonElement)ViewBag.Requests;
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card">
    <h5 class="section-title">✅ Pending WFH Approvals</h5>

    @if (!requests.EnumerateArray().Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h5>All caught up</h5>
            <p>No pending WFH requests to review.</p>
        </div>
    }
    else
    {
        <style>
            .approval-card {
                background: rgba(30, 41, 59, 0.4);
                border: 1px solid rgba(255,255,255,0.05);
                border-radius: 12px;
                padding: 20px;
                margin-bottom: 16px;
                transition: all 0.3s ease;
                border-left: 4px solid var(--ss-muted);
            }
            .approval-card:hover {
                background: rgba(30, 41, 59, 0.7);
                border-color: rgba(255,255,255,0.1);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            }
            .approval-card.approved { border-left-color: #10b981; }
            .approval-card.rejected { border-left-color: #ef4444; }
            .approval-card.pending { border-left-color: #f59e0b; }
        </style>
        
        <div class="mt-3">
            @foreach (var r in requests.EnumerateArray())
            {
                var id = r.GetProperty("id").GetInt32();
                var empId = r.GetProperty("employeeId").GetString();
                var reqType = r.GetProperty("requestType").GetString();
                var desc = r.GetProperty("description").GetString();
                var priority = r.GetProperty("priority").GetString();
                var status = r.GetProperty("status").GetString();
                var createdAt = r.GetProperty("createdAt").GetString();

                var statusClass = status == "Approved" ? "success"
                               : status == "Rejected" ? "error"
                               : "warning";
                               
                var cardClass = status == "Approved" ? "approved"
                               : status == "Rejected" ? "rejected"
                               : "pending";

                var priorityClass = priority == "High" ? "error"
                                 : priority == "Medium" ? "warning"
                                 : "success";

                <div class="approval-card @cardClass fade-in-up">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;"><i class="bi bi-person me-1"></i>Emp: @empId</span>
                                <span class="status-chip @priorityClass px-2 py-0" style="font-size: 10px;">@priority Priority</span>
                            </div>
                            <h6 class="text-white fw-bold m-0 d-flex align-items-center gap-2">
                                <i class="bi @(reqType == "WFH" ? "bi-house-laptop text-info" : reqType == "Counselling" ? "bi-heart-pulse text-danger" : reqType == "FlexiHours" ? "bi-clock-history text-warning" : "bi-bandaid text-success")"></i>
                                @reqType
                            </h6>
                            <div class="text-muted mt-1" style="font-size: 12px;">
                                <i class="bi bi-calendar-event me-1"></i>
                                Submitted on @TimeHelper.ToIST(createdAt!).ToString("dd MMM yyyy")
                            </div>
                        </div>
                        
                        <div class="d-flex flex-column align-items-end gap-2">
                            <span class="status-chip @statusClass fw-bold px-3 py-1" style="border-radius: 8px;">
                                @status
                            </span>
                            @if (status == "Pending")
                            {
                                <div class="d-flex gap-2">
                                    <form method="post" asp-action="UpdateStatus" class="m-0">
                                        <input type="hidden" name="requestId" value="@id" />
                                        <input type="hidden" name="status" value="Approved" />
                                        <button type="submit" class="btn btn-sm btn-outline-success border-0" style="background: rgba(16,185,129,0.1); border-radius: 6px; padding: 4px 12px;">
                                            <i class="bi bi-check2 me-1"></i>Approve
                                        </button>
                                    </form>
                                    <form method="post" asp-action="UpdateStatus" class="m-0">
                                        <input type="hidden" name="requestId" value="@id" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0" style="background: rgba(233,69,96,0.1); border-radius: 6px; padding: 4px 12px;">
                                            <i class="bi bi-x-lg me-1"></i>Reject
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                    
                    <p class="m-0 text-white opacity-75" style="font-size: 13px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 8px; line-height: 1.5;">
                        @desc
                    </p>
                </div>
            }
        </div>
    }
</div>

