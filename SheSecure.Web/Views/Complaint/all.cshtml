@{
    ViewData["Title"] = "All Complaints";
    var complaints = (System.Text.Json.JsonElement)ViewBag.Complaints;
    var currentUserEmail = Context.Session.GetString("Email") ?? Context.Session.GetString("Username") ?? "current_user";
}

<div class="glass-card">
    <h5 class="section-title">📂 All Complaints (HR/POSH)</h5>

    @if (!complaints.EnumerateArray().Any())
    {
        <div class="empty-state py-5">
            <div class="empty-state-icon" style="font-size: 48px; margin-bottom: 20px; opacity: 0.5;">📂</div>
            <h5 class="text-white">No complaints found</h5>
            <p class="text-muted">There are currently no complaints in the system.</p>
        </div>
    }
    else
    {
        <style>
            .complaint-card {
                background: rgba(30, 41, 59, 0.4);
                border: 1px solid rgba(255,255,255,0.05);
                border-radius: 16px;
                padding: 24px;
                margin-bottom: 20px;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
            }
            .complaint-card:hover {
                background: rgba(30, 41, 59, 0.7);
                border-color: rgba(255,255,255,0.1);
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            }
            .complaint-timeline {
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: relative;
                margin: 32px 0 16px 0;
                padding: 0 10px;
            }
            .complaint-timeline::before {
                content: '';
                position: absolute;
                top: 12px;
                left: 10%;
                right: 10%;
                height: 2px;
                background: rgba(255,255,255,0.05);
                z-index: 1;
            }
            .timeline-step {
                position: relative;
                z-index: 2;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 10px;
                flex: 1;
            }
            .timeline-dot {
                width: 26px;
                height: 26px;
                border-radius: 50%;
                background: var(--ss-card);
                border: 3px solid rgba(255,255,255,0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s ease;
                font-size: 10px;
                color: transparent;
            }
            .timeline-step.completed .timeline-dot {
                background: rgba(16, 185, 129, 0.1);
                border-color: #10b981;
                color: #10b981;
                box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            }
            .timeline-step.active .timeline-dot {
                background: rgba(233, 69, 96, 0.1);
                border-color: var(--ss-accent);
                color: var(--ss-accent);
                box-shadow: 0 0 15px rgba(233, 69, 96, 0.4);
                animation: pulse-ring 2s infinite;
            }
            .timeline-label {
                font-size: 11px;
                font-weight: 600;
                color: var(--ss-muted);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                text-align: center;
                transition: all 0.3s ease;
            }
            .timeline-step.completed .timeline-label { color: rgba(255,255,255,0.85); }
            .timeline-step.active .timeline-label { color: var(--ss-accent); font-weight: 700; }
            
            .complaint-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 12px;
            }
            .complaint-ref {
                font-family: 'JetBrains Mono', monospace;
                font-size: 12px;
                color: var(--ss-muted);
                background: rgba(255,255,255,0.05);
                padding: 4px 8px;
                border-radius: 6px;
                letter-spacing: 0.5px;
            }

            .heartbeat {
                animation: heartbeat 1.5s infinite;
            }

            @@keyframes heartbeat {
                0% { transform: scale(1); }
                14% { transform: scale(1.05); }
                28% { transform: scale(1); }
                42% { transform: scale(1.05); }
                70% { transform: scale(1); }
            }
        </style>

        <div class="d-flex align-items-center flex-wrap gap-2 mb-4">
            <button class="btn btn-ss filter-btn active" data-filter="all" style="border-radius: 20px; font-size: 13px; padding: 6px 16px;">All Cases</button>
            <button class="btn btn-ss-outline filter-btn" data-filter="unassigned" style="border-radius: 20px; font-size: 13px; padding: 6px 16px;">Inbox (Unassigned)</button>
            <button class="btn btn-ss-outline filter-btn" data-filter="mycases" style="border-radius: 20px; font-size: 13px; padding: 6px 16px;">My Cases</button>
            <button class="btn btn-ss-outline filter-btn" data-filter="closed" style="border-radius: 20px; font-size: 13px; padding: 6px 16px;">Closed</button>
        </div>

        <div class="mt-2" id="complaintsList">
            @foreach (var c in complaints.EnumerateArray())
            {
                var id = c.GetProperty("id").GetInt32();
                var cmpNum = c.GetProperty("complaintNumber").GetString() ?? "";
                var subject = c.GetProperty("subject").GetString();
                var status = c.GetProperty("status").GetString() ?? "Submitted";
                var category = c.TryGetProperty("category", out var catProp) ? catProp.GetString() ?? "General" : "General";
                var priority = c.TryGetProperty("priority", out var priProp) ? priProp.GetString() ?? "Low" : "Low";
                var assignedTo = c.TryGetProperty("assignedTo", out var asgProp) ? asgProp.GetString() : "";
                var createdAtStr = c.GetProperty("createdAt").GetString();
                var createdAt = createdAtStr != null ? TimeHelper.ToIST(createdAtStr) : DateTime.UtcNow.AddHours(5).AddMinutes(30);

                var isOverdue = status == "Submitted" && (DateTime.UtcNow.AddHours(5).AddMinutes(30) - createdAt).TotalHours > 48;

                int level = (status == "Resolved" || status == "Closed") ? 4 :
                            (status == "Under Investigation" || !string.IsNullOrEmpty(assignedTo)) ? 3 :
                            (status == "Under Review") ? 2 : 1;

                var chipClass = status == "Resolved" ? "success"
                               : status == "Under Investigation" ? "info"
                               : status == "Under Review" ? "warning"
                               : status == "Closed" ? "neutral"
                               : "warning";

                var priorityClass = priority == "Critical" ? "bg-danger text-white shadow" 
                                  : priority == "High" ? "bg-warning text-dark"
                                  : priority == "Medium" ? "bg-info text-dark"
                                  : "bg-secondary text-white";

                <div class="complaint-card-wrapper" data-assigned="@assignedTo" data-status="@status">
                    <div class="complaint-card fade-in-up">
                        <div class="complaint-header">
                        <div>
                            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                                <span class="complaint-ref">@(cmpNum.Length > 12 ? cmpNum.Substring(0, 12) + "..." : cmpNum)</span>
                                <span class="badge" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--ss-muted); font-size: 11px;">@category</span>
                                <span class="badge @priorityClass" style="font-size: 11px; letter-spacing: 0.5px;">@priority</span>
                                @if (!string.IsNullOrEmpty(assignedTo))
                                {
                                    <span class="badge" style="background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.3); color: var(--ss-info); font-size: 11px;">
                                        <i class="bi bi-person-badge me-1"></i>@assignedTo
                                    </span>
                                }
                                @if (isOverdue)
                                {
                                    <span class="badge bg-danger text-white shadow heartbeat" style="font-size: 11px; letter-spacing: 0.5px;">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>OVERDUE
                                    </span>
                                }
                            </div>
                            <h5 class="text-white fw-bold mb-1">@subject</h5>
                            <div style="font-size: 12px; color: var(--ss-muted);">
                                <i class="bi bi-clock me-1"></i> Submitted on @createdAt.ToString("MMM dd, yyyy 'at' hh:mm tt")
                            </div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <span class="status-chip @chipClass d-inline-flex align-items-center gap-2 px-3 py-1">
                                <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                                @status
                            </span>
                            <a asp-controller="Complaint" asp-action="Detail" asp-route-id="@id" class="btn-ss-outline" style="padding: 6px 16px; font-size: 12px; border-radius: 8px;">
                                View Details <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>

                    <div class="complaint-timeline">
                        <div class="timeline-step @(level >= 1 ? "completed" : "")">
                            <div class="timeline-dot"><i class="bi bi-check-lg"></i></div>
                            <div class="timeline-label">Submitted</div>
                        </div>
                        <div class="timeline-step @(level >= 2 ? (level == 2 ? "active" : "completed") : "")">
                            <div class="timeline-dot"><i class="bi @(level > 2 ? "bi-check-lg" : "bi-search")"></i></div>
                            <div class="timeline-label">Under Review</div>
                        </div>
                        <div class="timeline-step @(level >= 3 ? (level == 3 ? "active" : "completed") : "")">
                            <div class="timeline-dot"><i class="bi @(level > 3 ? "bi-check-lg" : "bi-person-badge")"></i></div>
                            <div class="timeline-label">Assigned</div>
                        </div>
                        <div class="timeline-step @(level >= 4 ? "completed active" : "")">
                            <div class="timeline-dot"><i class="bi bi-shield-check"></i></div>
                            <div class="timeline-label">Resolved</div>
                        </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var currentUser = '@currentUserEmail'.toLowerCase();
                
                document.querySelectorAll('.filter-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        // Reset all buttons
                        document.querySelectorAll('.filter-btn').forEach(b => {
                            b.classList.remove('active', 'btn-ss');
                            b.classList.add('btn-ss-outline');
                        });
                        
                        // Set active state
                        this.classList.remove('btn-ss-outline');
                        this.classList.add('active', 'btn-ss');
                        
                        var filter = this.getAttribute('data-filter');
                        
                        document.querySelectorAll('.complaint-card-wrapper').forEach(card => {
                            var assigned = (card.getAttribute('data-assigned') || '').toLowerCase();
                            var status = card.getAttribute('data-status');
                            
                            if (filter === 'all') {
                                card.style.display = 'block';
                            } else if (filter === 'unassigned') {
                                card.style.display = assigned === '' ? 'block' : 'none';
                            } else if (filter === 'mycases') {
                                // Match if the assigned string contains the user's email or username
                                card.style.display = (assigned !== '' && currentUser !== '' && assigned.includes(currentUser)) ? 'block' : 'none';
                            } else if (filter === 'closed') {
                                card.style.display = (status === 'Resolved' || status === 'Closed') ? 'block' : 'none';
                            }
                        });
                    });
                });
            });
        </script>
    }
</div>

