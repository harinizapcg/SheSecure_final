@{
    ViewData["Title"] = "All Complaints";
    var complaints = (System.Text.Json.JsonElement)ViewBag.Complaints;
}

<div class="glass-card">
    <h5 class="section-title">📂 All Complaints (HR/POSH)</h5>

    @if (!complaints.EnumerateArray().Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📂</div>
            <h5>No complaints found</h5>
            <p>There are currently no complaints in the system.</p>
        </div>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table-glass table border-0">
                <thead>
                    <tr>
                        <th>Ref No.</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in complaints.EnumerateArray())
                    {
                        var id = c.GetProperty("id").GetInt32();
                        var cmpNum = c.GetProperty("complaintNumber").GetString();
                        var subject = c.GetProperty("subject").GetString();
                        var status = c.GetProperty("status").GetString();
                        var createdAt = c.GetProperty("createdAt").GetString();

                        var chipClass = status == "Resolved" ? "success"
                                       : status == "Under Investigation" ? "info"
                                       : status == "Under Review" ? "warning"
                                       : status == "Closed" ? "neutral"
                                       : "warning";

                        <tr>
                            <td style="font-family: monospace; color: var(--ss-muted);">
                                @cmpNum?.Substring(0, Math.Min(12, cmpNum.Length))...
                            </td>
                            <td class="fw-medium">@subject</td>
                            <td>
                                <span class="status-chip @chipClass">
                                    @status
                                </span>
                            </td>
                            <td style="color: var(--ss-muted);">
                                @DateTime.Parse(createdAt!).ToString("dd MMM yyyy")
                            </td>
                            <td>
                                <a asp-controller="Complaint" asp-action="Detail" asp-route-id="@id" class="btn-ss-outline" style="padding: 4px 12px; font-size: 12px;">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
