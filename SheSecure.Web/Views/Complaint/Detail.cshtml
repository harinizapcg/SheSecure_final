@{
    ViewData["Title"] = "Complaint Detail";
    var complaint = (System.Text.Json.JsonElement)ViewBag.Complaint;
    var comments = (System.Text.Json.JsonElement)ViewBag.Comments;
    var history = (System.Text.Json.JsonElement)ViewBag.History;
    var role = Context.Session.GetString("Role") ?? "";

    var id = complaint.TryGetProperty("id", out var idProp) ? idProp.GetInt32() : 0;
    var cmpNum = complaint.TryGetProperty("complaintNumber", out var cn) ? cn.GetString() : "";
    var subject = complaint.TryGetProperty("subject", out var sub) ? sub.GetString() : "";
    var status = complaint.TryGetProperty("status", out var st) ? st.GetString() : "";

    var chipClass = status == "Resolved" ? "success"
                   : status == "Under Investigation" ? "info"
                   : status == "Under Review" ? "warning"
                   : status == "Closed" ? "neutral"
                   : "warning";
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4 fade-in-up">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4 fade-in-up">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- Complaint Header -->
<div class="glass-panel p-4 mb-4 fade-in-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold text-white">@subject</h4>
            <div style="font-size:13px; color:var(--ss-muted); font-family:monospace">
                REF: @cmpNum
            </div>
        </div>
        <span class="status-chip @chipClass" style="font-size: 13px; padding: 6px 16px;">
            @status
        </span>
    </div>
</div>

<div class="row g-4">
    <!-- Left: Comments + Upload -->
    <div class="col-md-7">
        <!-- Comments -->
        <div class="glass-card mb-4 fade-in-up delay-100">
            <h5 class="section-title">💬 Comments</h5>

            @if (!comments.EnumerateArray().Any())
            {
                <div class="empty-state py-4">
                    <p class="mb-0">No comments yet.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3 mt-3">
                    @foreach (var c in comments.EnumerateArray())
                    {
                        var uid = c.GetProperty("userId").GetInt32();
                        var comment = c.GetProperty("comment").GetString();
                        var isInternal = c.GetProperty("isInternal").GetBoolean();
                        var createdAt = c.GetProperty("createdAt").GetString();

                        <div class="p-3 hover-lift" style="background: @(isInternal ? "rgba(168,85,247,0.08)" : "rgba(15,23,42,0.5)"); border: 1px solid @(isInternal ? "rgba(168,85,247,0.2)" : "var(--ss-border)"); border-radius: 12px;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-medium text-white" style="font-size: 13px;">
                                    User #@uid
                                    @if (isInternal)
                                    {
                                        <span class="status-chip info ms-2" style="font-size: 10px; padding: 2px 8px;">Internal</span>
                                    }
                                </span>
                                <span style="font-size: 11px; color: var(--ss-muted);">
                                    @DateTime.Parse(createdAt!).ToString("dd MMM, hh:mm tt")
                                </span>
                            </div>
                            <div style="font-size: 14px; color: var(--ss-text);">
                                @comment
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Add Comment Form -->
            <form method="post" asp-action="AddComment" class="mt-4">
                <input type="hidden" name="complaintId" value="@id" />
                <div class="mb-3">
                    <textarea name="comment" rows="2" class="form-control" placeholder="Add a comment..." required style="resize: none;"></textarea>
                </div>
                @if (role == "HR" || role == "Admin")
                {
                    <div class="form-check mb-3 d-flex align-items-center gap-2">
                        <input type="checkbox" name="isInternal" value="true" class="form-check-input mt-0" id="internalCheck" />
                        <label class="form-check-label form-label mb-0" for="internalCheck" style="cursor: pointer;">
                            Internal comment (hidden from employee)
                        </label>
                    </div>
                }
                else
                {
                    <input type="hidden" name="isInternal" value="false" />
                }
                <button type="submit" class="btn-ss py-2 px-4 ripple">
                    <i class="bi bi-send me-2"></i>Add Comment
                </button>
            </form>
        </div>

        <!-- Upload Evidence -->
        <div class="glass-card fade-in-up delay-200">
            <h5 class="section-title">📎 Upload Evidence</h5>
            <form method="post" asp-action="UploadFile" enctype="multipart/form-data" class="mt-3">
                <input type="hidden" name="complaintId" value="@id" />
                <div class="d-flex gap-2">
                    <input type="file" name="file" class="form-control" required />
                    <button type="submit" class="btn-ss ripple">Upload</button>
                </div>
                <div class="mt-2" style="font-size: 12px; color: var(--ss-muted);">
                    Accepted formats: PDF, Images, Documents
                </div>
            </form>
        </div>
    </div>

    <!-- Right: Status Update + History -->
    <div class="col-md-5">
        <!-- Update Status (HR only) -->
        @if (role == "HR" || role == "Admin")
        {
            <div class="glass-card mb-4 fade-in-up delay-100">
                <h5 class="section-title">🔄 Update Status</h5>
                <form method="post" asp-action="UpdateStatus" class="mt-3">
                    <input type="hidden" name="complaintId" value="@id" />
                    <div class="mb-3">
                        <select name="status" class="form-select" required>
                            <option value="Submitted">Submitted</option>
                            <option value="Under Review">Under Review</option>
                            <option value="Under Investigation">Under Investigation</option>
                            <option value="Resolved">Resolved</option>
                            <option value="Closed">Closed</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <textarea name="resolutionNotes" rows="2" class="form-control" placeholder="Resolution notes..." style="resize: none;"></textarea>
                    </div>
                    <button type="submit" class="btn-ss w-100 py-2 ripple">
                        Update Status
                    </button>
                </form>
            </div>
        }

        <!-- Status History Timeline -->
        <div class="glass-card fade-in-up delay-200 h-100">
            <h5 class="section-title">🕐 Status History</h5>
            @if (!history.EnumerateArray().Any())
            {
                <div class="empty-state py-4">
                    <p class="mb-0">No history yet.</p>
                </div>
            }
            else
            {
                <div class="timeline-container">
                    @{
                        var historyArray = history.EnumerateArray().ToArray();
                        for (int i = 0; i < historyArray.Length; i++)
                        {
                            var h = historyArray[i];
                            var oldSt = h.GetProperty("oldStatus").GetString();
                            var newSt = h.GetProperty("newStatus").GetString();
                            var remarks = h.GetProperty("remarks").GetString();
                            var changedAt = h.GetProperty("changedAt").GetString();
                            var isLatest = i == historyArray.Length - 1; // latest is at the end of the array typically, or reverse? Assuming last is latest

                            <div class="timeline-item @(isLatest ? "active" : "")">
                                <div class="fw-bold text-white mb-1" style="font-size: 14px;">
                                    Status updated to <span class="text-gradient">@newSt</span>
                                </div>
                                <div class="mb-1" style="font-size: 12px; color: var(--ss-muted);">
                                    Previously: @oldSt
                                </div>
                                @if (!string.IsNullOrEmpty(remarks))
                                {
                                    <div class="p-2 mt-2" style="background: rgba(255,255,255,0.05); border-radius: 8px; font-size: 13px; color: var(--ss-text);">
                                        @remarks
                                    </div>
                                }
                                <div class="mt-2 fw-medium" style="font-size: 11px; color: var(--ss-muted);">
                                    @DateTime.Parse(changedAt!).ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="mt-4 fade-in-up delay-300">
    <a asp-action="Index" class="btn-ss-outline ripple" style="text-decoration: none;">
        <i class="bi bi-arrow-left me-2"></i>Back to Complaints
    </a>
</div>
