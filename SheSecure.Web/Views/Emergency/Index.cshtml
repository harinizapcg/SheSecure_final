@{
    ViewData["Title"] = "SOS / Emergency";
    var alerts = (System.Text.Json.JsonElement)ViewBag.Alerts;
    var activeCount = alerts.EnumerateArray()
                            .Count(a => a.GetProperty("status").GetString() == "Active");
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4 fade-in-up">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4 fade-in-up">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="row g-4">
    <!-- SOS Trigger Form -->
    <div class="col-md-4">
        <!-- Big SOS Button -->
        <div class="glass-card mb-4 text-center py-5 fade-in-up position-relative overflow-hidden" style="border: 2px solid rgba(239, 68, 68, 0.3);">
            <div class="floating-shape" style="background: var(--ss-alert); width: 150px; height: 150px; filter: blur(50px); opacity: 0.2; top: 50%; left: 50%; transform: translate(-50%, -50%); animation: none;"></div>
            <h6 class="mb-4 text-white position-relative" style="z-index: 2;">Press in case of emergency</h6>
            
            <div class="position-relative d-inline-block" style="z-index: 2;">
                <!-- Pulsing background rings -->
                <div style="position: absolute; top: -10px; left: -10px; right: -10px; bottom: -10px; border-radius: 50%; border: 2px solid var(--ss-alert); animation: pulse-ring 1.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1);"></div>
                <div style="position: absolute; top: -20px; left: -20px; right: -20px; bottom: -20px; border-radius: 50%; border: 1px solid var(--ss-alert); animation: pulse-ring 1.5s infinite 0.3s cubic-bezier(0.215, 0.61, 0.355, 1);"></div>
                
                <button onclick="document.getElementById('sosForm').scrollIntoView({behavior:'smooth'})"
                        class="btn-sos shadow-lg position-relative" style="z-index: 3;">
                    SOS
                </button>
            </div>
            
            <p class="mt-5 mb-0" style="font-size: 13px; color: var(--ss-muted); z-index: 2; position: relative;">Security will be notified immediately</p>
        </div>

        <!-- SOS Form -->
        <div class="glass-card fade-in-up delay-100" id="sosForm">
            <h5 class="section-title text-danger d-flex align-items-center">
                <span class="d-inline-block me-2" style="width: 12px; height: 12px; background: var(--ss-danger); border-radius: 50%; box-shadow: 0 0 10px var(--ss-danger); animation: pulse-sos 2s infinite;"></span>
                Trigger SOS Alert
            </h5>
            <form method="post" asp-action="SOS" class="mt-4">
                <div class="mb-3">
                    <label class="form-label">Your Location</label>
                    <input type="text" name="location" class="form-control" placeholder="e.g. Block A - Parking Area" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Severity</label>
                    <select name="severity" class="form-select" required>
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High" selected>High</option>
                        <option value="Critical">Critical</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label">Description</label>
                    <textarea name="description" rows="3" class="form-control" placeholder="Briefly describe the situation..." required style="resize: none;"></textarea>
                </div>
                <button type="submit" class="btn btn-danger w-100 py-3 fw-bold ripple" style="border-radius: 12px; background: linear-gradient(135deg, #e94560, #b91c1c); border: none; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4); text-transform: uppercase; letter-spacing: 1px;">
                    🚨 Send SOS Alert
                </button>
            </form>
        </div>
    </div>

    <!-- My Alert History -->
    <div class="col-md-8">
        @if (activeCount > 0)
        {
            <div class="alert-glass error mb-4 fade-in-up">
                <i class="bi bi-exclamation-triangle-fill fs-5 text-danger" style="animation: pulse-sos 2s infinite;"></i>
                <span>You have <strong>@activeCount active</strong> SOS alert(s). Security has been notified.</span>
            </div>
        }

        <div class="glass-card h-100 fade-in-up delay-200">
            <h5 class="section-title">📋 My Alert History</h5>

            @if (!alerts.EnumerateArray().Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 24px; animation: float 6s ease-in-out infinite;">🛡</div>
                    <h5 class="text-white">No emergencies reported</h5>
                    <p>You have not triggered any SOS alerts.</p>
                </div>
            }
            else
            {
                <div class="table-responsive mt-3">
                    <table class="table-glass table border-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Location</th>
                                <th>Description</th>
                                <th>Severity</th>
                                <th>Status</th>
                                <th>Triggered</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in alerts.EnumerateArray())
                            {
                                var id = a.GetProperty("id").GetInt32();
                                var location = a.GetProperty("location").GetString();
                                var description = a.GetProperty("description").GetString();
                                var severity = a.GetProperty("severity").GetString();
                                var status = a.GetProperty("status").GetString();
                                var triggeredAt = a.GetProperty("triggeredAt").GetString();

                                var statusClass = status == "Active" ? "error" : "success";
                                var severityClass = severity == "Critical" ? "error"
                                                 : severity == "High" ? "warning"
                                                 : severity == "Medium" ? "info"
                                                 : "success";

                                <tr class="hover-lift">
                                    <td class="text-muted">#@id</td>
                                    <td class="fw-medium text-white">@location</td>
                                    <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color: var(--ss-muted);">
                                        @description
                                    </td>
                                    <td>
                                        <span class="status-chip @severityClass">@severity</span>
                                    </td>
                                    <td>
                                        <span class="status-chip @statusClass">
                                            @if(status == "Active") { <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;animation:pulse-sos 1s infinite;"></span> }
                                            @status
                                        </span>
                                    </td>
                                    <td style="color: var(--ss-muted); font-size: 13px;">
                                        @DateTime.Parse(triggeredAt!).ToString("dd MMM, hh:mm tt")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    @@keyframes pulse-ring {
        0% { transform: scale(0.8); opacity: 0.8; }
        100% { transform: scale(1.5); opacity: 0; }
    }
    .btn-sos {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--ss-alert), #991b1b);
        border: 4px solid var(--ss-bg);
        color: white;
        font-size: 28px;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 0 30px rgba(239, 68, 68, 0.4);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }
    .btn-sos:hover {
        transform: scale(1.05);
        box-shadow: 0 0 50px rgba(239, 68, 68, 0.6);
        background: linear-gradient(135deg, #f87171, #dc2626);
    }
    .btn-sos:active {
        transform: scale(0.95);
        box-shadow: 0 0 20px rgba(239, 68, 68, 0.8);
    }
</style>
