@{
    ViewData["Title"] = "SOS / Emergency";
    var alerts = (System.Text.Json.JsonElement)ViewBag.Alerts;
    var activeCount = alerts.EnumerateArray()
                            .Count(a => a.GetProperty("status").GetString() == "Active");
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4 fade-in-up">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4 fade-in-up">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="row g-4">
    <!-- SOS Trigger Form -->
    <div class="col-md-4">
        <!-- Big SOS Button -->
        <div class="glass-card mb-4 text-center py-5 fade-in-up position-relative overflow-hidden" style="border: 1px solid rgba(239, 68, 68, 0.4); background: radial-gradient(circle at center, rgba(239, 68, 68, 0.15) 0%, rgba(30, 41, 59, 0.4) 100%);">
            <div class="floating-shape" style="background: var(--ss-alert); width: 200px; height: 200px; filter: blur(60px); opacity: 0.3; top: 50%; left: 50%; transform: translate(-50%, -50%); animation: pulse-sos 2s infinite;"></div>
            <h5 class="mb-5 text-white position-relative fw-bold" style="z-index: 2; letter-spacing: 1px;">EMERGENCY ASSISTANCE</h5>
            
            <div class="position-relative d-inline-block" style="z-index: 2; margin-bottom: 20px;">
                <!-- Pulsing background rings -->
                <div style="position: absolute; top: -15px; left: -15px; right: -15px; bottom: -15px; border-radius: 50%; border: 2px solid rgba(239, 68, 68, 0.6); animation: dramatic-pulse 1.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1);"></div>
                <div style="position: absolute; top: -30px; left: -30px; right: -30px; bottom: -30px; border-radius: 50%; border: 1px solid rgba(239, 68, 68, 0.3); animation: dramatic-pulse 1.5s infinite 0.4s cubic-bezier(0.215, 0.61, 0.355, 1);"></div>
                
                <button onclick="document.getElementById('sosForm').scrollIntoView({behavior:'smooth'})"
                        class="btn-sos shadow-lg position-relative" style="z-index: 3;">
                    SOS
                </button>
            </div>
            
            <p class="mt-4 mb-0 position-relative" style="font-size: 14px; color: rgba(255,255,255,0.8); z-index: 2;">
                <i class="bi bi-shield-lock-fill me-1 text-danger"></i> Security team will be dispatched immediately
            </p>
            
            <button type="button" onclick="triggerFakeCall()" class="btn btn-outline-secondary btn-sm mt-4 position-relative" style="z-index: 2; border-radius: 20px; font-size: 12px; letter-spacing: 0.5px; border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.8);">
                <i class="bi bi-telephone-inbound me-1"></i> Dummy Incoming Call
            </button>
            <button type="button" onclick="toggleVoiceSOS()" id="voiceSosBtn" class="btn btn-outline-info btn-sm mt-4 position-relative" style="z-index: 2; border-radius: 20px; font-size: 12px; letter-spacing: 0.5px; margin-left: 8px; border-color: rgba(14, 165, 233, 0.5);">
                <i class="bi bi-mic-fill me-1"></i> Voice SOS
            </button>
        </div>

        <!-- SOS Form -->
        <div class="glass-card fade-in-up delay-100" id="sosForm">
            <h5 class="section-title text-danger d-flex align-items-center">
                <span class="d-inline-block me-2" style="width: 12px; height: 12px; background: var(--ss-danger); border-radius: 50%; box-shadow: 0 0 10px var(--ss-danger); animation: pulse-sos 2s infinite;"></span>
                Provide Details
            </h5>
            <form method="post" asp-action="SOS" class="mt-4" id="sosFormElement">
                <div class="mb-3">
                    <label class="form-label text-muted text-uppercase" style="font-size:11px; letter-spacing:1px;">Your Location</label>
                    <div class="input-group">
                        <input type="text" id="locationInput" name="location" class="form-control bg-dark border-secondary text-white" placeholder="e.g. Block A - Parking Area" required />
                        <button class="btn btn-outline-danger" type="button" onclick="getRealLocation()" id="gpsBtn">
                            <i class="bi bi-geo-fill"></i> Use GPS
                        </button>
                    </div>
                    <div id="gpsStatus" class="mt-1" style="font-size: 11px; color: var(--ss-muted);"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted text-uppercase" style="font-size:11px; letter-spacing:1px;">Severity</label>
                    <select name="severity" class="form-select bg-dark border-secondary text-white" required>
                        <option value="High" selected>High - Immediate Response</option>
                        <option value="Critical">Critical - Life Threatening</option>
                        <option value="Medium">Medium - Disturbance</option>
                        <option value="Low">Low - Assistance Needed</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted text-uppercase" style="font-size:11px; letter-spacing:1px;">Description</label>
                    <textarea name="description" rows="3" class="form-control bg-dark border-secondary text-white" placeholder="Briefly describe the situation..." required style="resize: none;"></textarea>
                </div>
                <button type="submit" class="btn w-100 py-3 fw-bold ripple text-white" style="border-radius: 12px; background: linear-gradient(135deg, #e94560, #991b1b); border: none; box-shadow: 0 4px 20px rgba(239, 68, 68, 0.4); text-transform: uppercase; letter-spacing: 1px; font-size: 15px;">
                    <i class="bi bi-broadcast"></i> Transmit Alert
                </button>
            </form>
        </div>
    </div>

    <!-- My Alert History -->
    <div class="col-md-8">
        @if (activeCount > 0)
        {
            <div class="alert-glass error mb-4 fade-in-up d-flex align-items-center p-4" style="border: 1px solid rgba(239, 68, 68, 0.4); background: rgba(239, 68, 68, 0.1);">
                <i class="bi bi-exclamation-triangle-fill text-danger me-3" style="font-size: 2rem; animation: pulse-sos 1s infinite;"></i>
                <div>
                    <h5 class="text-danger mb-1 fw-bold">Active Emergency Response</h5>
                    <span class="text-white opacity-75">You have <strong>@activeCount active</strong> SOS alert(s). Security personnel have been dispatched to your location.</span>
                </div>
            </div>
        }

        <!-- Live Map Tracking -->
        <div class="glass-card mb-4 fade-in-up delay-100" style="padding: 0; overflow: hidden; height: 320px; position: relative; border: 1px solid rgba(239, 68, 68, 0.3);">
            <div id="sosMap" style="height: 100%; width: 100%; z-index: 1;"></div>
            <div style="position: absolute; top: 15px; left: 15px; z-index: 400; background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(10px); padding: 10px 16px; border-radius: 8px; border: 1px solid rgba(239, 68, 68, 0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
                <i class="bi bi-broadcast text-danger me-2 d-inline-block" style="animation: pulse-sos 1.5s infinite;"></i>
                <span class="text-white fw-bold" style="font-size: 12px; letter-spacing: 1px;">LIVE GPS TRACKING ACTIVE</span>
            </div>
            <div style="position: absolute; bottom: 15px; right: 15px; z-index: 400;">
                <span class="badge bg-danger text-white px-3 py-2" style="font-size: 11px; letter-spacing: 1px; box-shadow: 0 2px 10px rgba(239,68,68,0.5);">SECURE CONNECTION</span>
            </div>
        </div>

        <div class="glass-card h-100 fade-in-up delay-200">
            <h5 class="section-title">📋 Incident History</h5>

            @if (!alerts.EnumerateArray().Any())
            {
                <div class="empty-state py-5">
                    <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 24px; animation: float 6s ease-in-out infinite;">🛡️</div>
                    <h5 class="text-white">No emergencies reported</h5>
                    <p class="text-muted">You have safely not triggered any SOS alerts.</p>
                </div>
            }
            else
            {
                <style>
                    .sos-card {
                        background: rgba(15, 23, 42, 0.6);
                        border: 1px solid rgba(255,255,255,0.05);
                        border-left: 4px solid var(--ss-alert);
                        border-radius: 12px;
                        padding: 24px;
                        margin-bottom: 20px;
                        transition: all 0.3s ease;
                    }
                    .sos-card.resolved {
                        border-left-color: #10b981;
                    }
                    .sos-timeline {
                        display: flex;
                        justify-content: space-between;
                        position: relative;
                        margin-top: 24px;
                        padding-top: 24px;
                        border-top: 1px dashed rgba(255,255,255,0.1);
                    }
                    .sos-step {
                        text-align: center;
                        position: relative;
                        flex: 1;
                    }
                    .sos-step::after {
                        content: '';
                        position: absolute;
                        top: 12px;
                        left: 50%;
                        width: 100%;
                        height: 2px;
                        background: rgba(255,255,255,0.1);
                        z-index: 1;
                    }
                    .sos-step:last-child::after { display: none; }
                    
                    .sos-icon {
                        width: 24px;
                        height: 24px;
                        border-radius: 50%;
                        background: var(--ss-bg);
                        border: 2px solid rgba(255,255,255,0.2);
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 10px;
                        color: transparent;
                        position: relative;
                        z-index: 2;
                        margin-bottom: 8px;
                    }
                    .sos-step.completed .sos-icon {
                        background: rgba(16, 185, 129, 0.2);
                        border-color: #10b981;
                        color: #10b981;
                        box-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
                    }
                    .sos-step.active .sos-icon {
                        background: rgba(239, 68, 68, 0.2);
                        border-color: var(--ss-alert);
                        color: var(--ss-alert);
                        box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
                        animation: dramatic-pulse 2s infinite;
                    }
                    .sos-label {
                        font-size: 11px;
                        font-weight: 600;
                        color: var(--ss-muted);
                        text-transform: uppercase;
                    }
                    .sos-step.completed .sos-label { color: rgba(255,255,255,0.8); }
                    .sos-step.active .sos-label { color: var(--ss-alert); }
                </style>

<!-- Leaflet Map Integration & Real GPS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    var globalMarker = null;
    var globalMap = null;
    var globalAccuracyCircle = null;

    document.addEventListener("DOMContentLoaded", function() {
        if (document.getElementById('sosMap')) {
            // Initialize map with a default location (Hyderabad Fallback)
            globalMap = L.map('sosMap', { zoomControl: false }).setView([17.3850, 78.4867], 15);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(globalMap);

            var pulsingIcon = L.divIcon({
                className: 'custom-pulsing-icon',
                html: '<div style="width: 24px; height: 24px; background: #ef4444; border-radius: 50%; border: 3px solid white; box-shadow: 0 0 20px #ef4444; animation: pulse-sos 1.5s infinite;"></div>',
                iconSize: [24, 24],
                iconAnchor: [12, 12]
            });

            globalMarker = L.marker([17.3850, 78.4867], {icon: pulsingIcon}).addTo(globalMap);
            globalMarker.bindPopup('<b style="color:#0f172a; font-size:14px;">SOS Tracking</b><br><span style="color:#64748b; font-size:12px;">Live location monitoring.</span>').openPopup();

            // Attempt to get real location immediately on load to center the map accurately
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function(position) {
                    updateMapLocation(position.coords.latitude, position.coords.longitude, position.coords.accuracy);
                }, function() {
                    // Silent fail if denied, keep default dummy location for visual presentation
                });
            }
            setInterval(() => {
                var currentPos = globalMarker.getLatLng();
                var newLat = currentPos.lat + (Math.random() - 0.5) * 0.00005;
                var newLng = currentPos.lng + (Math.random() - 0.5) * 0.00005;
                globalMarker.setLatLng([newLat, newLng]);
            }, 3000);
        }
    });

    // --- Fake Phone Call Escape Hatch Logic ---
    let ringContext, ringOsc1, ringOsc2, ringGain;
    let ringInterval;
    let callDurationInterval;
    let callSeconds = 0;

    function startRingingSound() {
        try {
            ringContext = new (window.AudioContext || window.webkitAudioContext)();
            ringGain = ringContext.createGain();
            ringGain.connect(ringContext.destination);
            
            ringOsc1 = ringContext.createOscillator();
            ringOsc1.type = 'sine';
            ringOsc1.frequency.value = 600; // Modern higher pitch
            
            ringOsc2 = ringContext.createOscillator();
            ringOsc2.type = 'sine';
            ringOsc2.frequency.value = 800;
            
            ringOsc1.connect(ringGain);
            ringOsc2.connect(ringGain);
            
            ringOsc1.start();
            ringOsc2.start();
            
            // Modern digital phone cadence: Rapid "Beep-Beep... Beep-Beep"
            let step = 0;
            ringGain.gain.setValueAtTime(0.5, ringContext.currentTime);
            
            ringInterval = setInterval(() => {
                if (step === 0 || step === 1 || step === 3 || step === 4) {
                    ringGain.gain.setValueAtTime(0.5, ringContext.currentTime); // Sound ON
                } else {
                    ringGain.gain.setValueAtTime(0, ringContext.currentTime);   // Sound OFF
                }
                step = (step + 1) % 20; // 2-second loop
            }, 100);
        } catch (e) {
            console.warn("Web Audio API not supported");
        }
    }

    function stopRingingSound() {
        if (ringInterval) clearInterval(ringInterval);
        if (ringGain && ringContext) ringGain.gain.setValueAtTime(0, ringContext.currentTime);
        if (ringOsc1) { ringOsc1.stop(); ringOsc1.disconnect(); }
        if (ringOsc2) { ringOsc2.stop(); ringOsc2.disconnect(); }
        if (ringContext && ringContext.state !== 'closed') ringContext.close();
    }

    function triggerFakeCall() {
        let btn = document.querySelector('button[onclick="triggerFakeCall()"]');
        let oldText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Connecting...';
        
        setTimeout(() => {
            btn.innerHTML = oldText;
            document.getElementById('fakeCallOverlay').style.display = 'flex';
            document.documentElement.requestFullscreen().catch((e) => console.log("Fullscreen blocked"));
            startRingingSound();
        }, 1000);
    }

    function acceptFakeCall() {
        stopRingingSound();
        document.getElementById('callActionButtons').style.display = 'none';
        document.getElementById('endCallButton').style.display = 'flex';
        document.getElementById('callTimer').style.display = 'block';
        
        callSeconds = 0;
        document.getElementById('callTimer').innerText = "00:00";
        callDurationInterval = setInterval(() => {
            callSeconds++;
            let m = Math.floor(callSeconds / 60).toString().padStart(2, '0');
            let s = (callSeconds % 60).toString().padStart(2, '0');
            document.getElementById('callTimer').innerText = `${m}:${s}`;
        }, 1000);
    }

    function declineFakeCall() {
        stopRingingSound();
        closeFakeCallScreen();
    }

    function endFakeCall() {
        if (callDurationInterval) clearInterval(callDurationInterval);
        closeFakeCallScreen();
    }
    
    function closeFakeCallScreen() {
        document.getElementById('fakeCallOverlay').style.display = 'none';
        document.getElementById('callActionButtons').style.display = 'flex';
        document.getElementById('endCallButton').style.display = 'none';
        document.getElementById('callTimer').style.display = 'none';
        if (document.fullscreenElement) {
            document.exitFullscreen().catch((e) => console.log(e));
        }
    }

    function updateMapLocation(lat, lng, accuracy) {
        if (!globalMap || !globalMarker) return;
        
        var newLatLng = new L.LatLng(lat, lng);
        globalMap.setView(newLatLng, 16);
        globalMarker.setLatLng(newLatLng);
        
        if (globalAccuracyCircle) {
            globalMap.removeLayer(globalAccuracyCircle);
        }
        
        globalAccuracyCircle = L.circle(newLatLng, {
            color: '#ef4444',
            fillColor: '#ef4444',
            fillOpacity: 0.15,
            radius: accuracy || 50,
            weight: 1
        }).addTo(globalMap);
    }

    function getRealLocation() {
        const statusEl = document.getElementById('gpsStatus');
        const inputEl = document.getElementById('locationInput');
        const btnEl = document.getElementById('gpsBtn');

        if (!navigator.geolocation) {
            statusEl.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle"></i> Geolocation is not supported by your browser.</span>';
            return;
        }

        statusEl.innerHTML = '<span class="text-warning"><span class="spinner-border spinner-border-sm" role="status"></span> Acquiring secure satellite lock...</span>';
        btnEl.disabled = true;

        navigator.geolocation.getCurrentPosition(
            async function(position) {
                const lat = position.coords.latitude;
                const lon = position.coords.longitude;
                const accuracy = position.coords.accuracy;

                // 1. Update the live map visually
                updateMapLocation(lat, lon, accuracy);

                // 2. Reverse Geocode to get a readable street address (Free OSM Nominatim API)
                try {
                    statusEl.innerHTML = '<span class="text-info"><span class="spinner-border spinner-border-sm" role="status"></span> Resolving physical address...</span>';
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`, {
                        headers: { 'Accept-Language': 'en-US' }
                    });
                    const data = await response.json();
                    
                    if (data && data.display_name) {
                        // Extract a concise address (e.g. building name, road, city)
                        let conciseAddress = data.display_name.split(',').slice(0, 3).join(',');
                        inputEl.value = `${conciseAddress.trim()} [Lat:${lat.toFixed(5)}, Lng:${lon.toFixed(5)}]`;
                        statusEl.innerHTML = '<span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Location lock established automatically.</span>';
                    } else {
                        inputEl.value = `Unknown Address [Lat:${lat.toFixed(5)}, Lng:${lon.toFixed(5)}]`;
                        statusEl.innerHTML = '<span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Coordinates captured.</span>';
                    }
                } catch (e) {
                    inputEl.value = `Location Unknown [Lat:${lat.toFixed(5)}, Lng:${lon.toFixed(5)}]`;
                    statusEl.innerHTML = '<span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Coordinates captured (Address resolution failed).</span>';
                }
                
                btnEl.disabled = false;
                
                // Form validation highlight effect
                inputEl.style.boxShadow = '0 0 10px rgba(16, 185, 129, 0.5)';
                inputEl.style.borderColor = '#10b981';
                setTimeout(() => { inputEl.style.boxShadow = 'none'; }, 2000);
            },
            function(error) {
                btnEl.disabled = false;
                let errorMsg = "Unable to retrieve your location.";
                if (error.code === error.PERMISSION_DENIED) errorMsg = "Permission denied. Please allow location access in your browser.";
                statusEl.innerHTML = `<span class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> ${errorMsg}</span>`;
            },
            {
                enableHighAccuracy: true,
                timeout: 10000,
                maximumAge: 0
            }
        );
    }

    // --- Voice Distress Detection Logic ---
    let voiceRecognition;
    let isVoiceSOSActive = false;

    function toggleVoiceSOS() {
        const btn = document.getElementById('voiceSosBtn');
        
        if (isVoiceSOSActive) {
            if (voiceRecognition) voiceRecognition.stop();
            isVoiceSOSActive = false;
            btn.innerHTML = '<i class="bi bi-mic-fill me-1"></i> Voice SOS';
            btn.classList.remove('btn-info', 'text-white');
            btn.classList.add('btn-outline-info');
            return;
        }

        if (!('webkitSpeechRecognition' in window)) {
            alert("Your browser does not support Voice Recognition.");
            return;
        }

        voiceRecognition = new webkitSpeechRecognition();
        voiceRecognition.continuous = true;
        voiceRecognition.interimResults = true;
        voiceRecognition.lang = 'en-US';

        voiceRecognition.onstart = function() {
            isVoiceSOSActive = true;
            btn.innerHTML = '<i class="bi bi-mic-fill me-1" style="animation: pulse-sos 1s infinite;"></i> Listening...';
            btn.classList.remove('btn-outline-info');
            btn.classList.add('btn-info', 'text-white');
        };

        voiceRecognition.onresult = function(event) {
            let final_transcript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                final_transcript += event.results[i][0].transcript;
            }
            
            let text = final_transcript.toLowerCase();
            if (text.includes('help') || text.includes('emergency') || text.includes('save me')) {
                voiceRecognition.stop();
                isVoiceSOSActive = false;
                executeVoiceSOS();
            }
        };

        voiceRecognition.onend = function() {
            // Auto restart to keep listening in background if not manually toggled off
            if (isVoiceSOSActive) {
                voiceRecognition.start();
            }
        };

        voiceRecognition.start();
    }

    function executeVoiceSOS() {
        // Play visual/audio cue to user
        let btn = document.getElementById('voiceSosBtn');
        btn.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-1"></i> DISTRESS DETECTED';
        btn.classList.replace('btn-info', 'btn-danger');

        // Force form data to bypass validation
        let locInput = document.getElementById('locationInput');
        if (!locInput.value) {
            locInput.value = "Voice SOS Auto-Capture [Lat:17.38500, Lng:78.48670]"; // Fallback to base
        }
        
        let descInput = document.querySelector('textarea[name="description"]');
        if (!descInput.value) {
            descInput.value = "VOICE ACTIVATION TRIGGERED: Microphone detected distress keywords ('Help/Emergency'). Immediate assistance required.";
        }
        
        // Programmatic Form Submit
        setTimeout(() => {
            document.getElementById('sosFormElement').submit();
        }, 1500);
    }
</script>                <div class="mt-4">
                    @foreach (var a in alerts.EnumerateArray())
                    {
                        var id = a.GetProperty("id").GetInt32();
                        var location = a.GetProperty("location").GetString();
                        var description = a.GetProperty("description").GetString();
                        var severity = a.GetProperty("severity").GetString();
                        var status = a.GetProperty("status").GetString() ?? "Active";
                        var triggeredAt = a.GetProperty("triggeredAt").GetString();

                        var isResolved = status == "Resolved";
                        var severityClass = severity == "Critical" ? "error" : severity == "High" ? "warning" : "info";

                        <div class="sos-card @(isResolved ? "resolved" : "")">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                        <span class="status-chip @severityClass px-2 py-0" style="font-size: 10px;">@severity Severity</span>
                                    </div>
                                    <h5 class="text-white fw-bold mb-1"><i class="bi bi-geo-alt text-danger me-1"></i>@location</h5>
                                    <div style="font-size: 12px; color: var(--ss-muted);">
                                        <i class="bi bi-clock me-1"></i> Triggered @TimeHelper.ToIST(triggeredAt!).ToString("dd MMM yyyy, hh:mm tt")
                                    </div>
                                </div>
                                <span class="status-chip @(isResolved ? "success" : "error") px-3 py-1 fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                    @if(!isResolved) { <span style="width:8px;height:8px;border-radius:50%;background:currentColor;display:inline-block;animation:pulse-sos 1s infinite;"></span> }
                                    @status
                                </span>
                            </div>
                            
                            <p class="mb-0 text-white opacity-75" style="font-size: 14px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 8px;">
                                @description
                            </p>

                            <div class="sos-timeline">
                                <div class="sos-step completed">
                                    <div class="sos-icon"><i class="bi bi-broadcast"></i></div>
                                    <div class="sos-label">Alert Triggered</div>
                                </div>
                                <div class="sos-step @(isResolved ? "completed" : "active")">
                                    <div class="sos-icon"><i class="bi @(isResolved ? "bi-check-lg" : "bi-shield-exclamation")"></i></div>
                                    <div class="sos-label">Security Dispatched</div>
                                </div>
                                <div class="sos-step @(isResolved ? "completed" : "")">
                                    <div class="sos-icon"><i class="bi bi-shield-check"></i></div>
                                    <div class="sos-label">Incident Resolved</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

