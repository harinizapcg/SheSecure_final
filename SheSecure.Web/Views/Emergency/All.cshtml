@{
    ViewData["Title"] = "All Emergency Alerts";
    var alerts = (System.Text.Json.JsonElement)ViewBag.Alerts;
    var role = Context.Session.GetString("Role") ?? "";
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card">
    <h5 class="section-title text-danger">🚨 All Emergency Alerts</h5>

    @if (!alerts.EnumerateArray().Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h5>All clear</h5>
            <p>There are no emergency alerts at this time.</p>
        </div>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table-glass table border-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Employee ID</th>
                        <th>Location</th>
                        <th>Description</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Triggered</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in alerts.EnumerateArray())
                    {
                        var id = a.GetProperty("id").GetInt32();
                        var empId = a.GetProperty("employeeId").GetString();
                        var location = a.GetProperty("location").GetString();
                        var description = a.GetProperty("description").GetString();
                        var severity = a.GetProperty("severity").GetString();
                        var status = a.GetProperty("status").GetString();
                        var triggeredAt = a.GetProperty("triggeredAt").GetString();

                        var statusClass = status == "Active" ? "error" : "success";
                        var severityClass = severity == "Critical" ? "error"
                                         : severity == "High" ? "warning"
                                         : severity == "Medium" ? "info"
                                         : "success";

                        <tr>
                            <td class="text-muted">#@id</td>
                            <td class="fw-medium text-white">@empId</td>
                            <td>@location</td>
                            <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color: var(--ss-muted);">
                                @description
                            </td>
                            <td>
                                <span class="status-chip @severityClass">@severity</span>
                            </td>
                            <td>
                                <span class="status-chip @statusClass">@status</span>
                            </td>
                            <td style="color: var(--ss-muted); font-size: 13px;">
                                @DateTime.Parse(triggeredAt!).ToString("dd MMM, hh:mm tt")
                            </td>
                            <td>
                                @if (status == "Active" && (role == "Security" || role == "Admin"))
                                {
                                    <form method="post" asp-action="Resolve" class="m-0">
                                        <input type="hidden" name="alertId" value="@id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success border-0" style="background: rgba(16,185,129,0.1); border-radius: 8px;">
                                            <i class="bi bi-check2-all me-1"></i>Resolve
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
