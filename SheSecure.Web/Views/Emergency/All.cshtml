@{
    ViewData["Title"] = "All Emergency Alerts";
    var alerts = (System.Text.Json.JsonElement)ViewBag.Alerts;
    var role = Context.Session.GetString("Role") ?? "";
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card mb-4" style="padding: 0; overflow: hidden; height: 450px; position: relative; border: 1px solid rgba(14, 165, 233, 0.4);">
    <div id="commandCenterMap" style="height: 100%; width: 100%; z-index: 1;"></div>
    <div style="position: absolute; top: 15px; left: 15px; z-index: 400; background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(10px); padding: 10px 16px; border-radius: 8px; border: 1px solid rgba(14, 165, 233, 0.5); box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
        <i class="bi bi-globe me-2 text-info d-inline-block"></i>
        <span class="text-white fw-bold" style="font-size: 13px; letter-spacing: 1px;">GLOBAL COMMAND CENTER - ACTIVE TRACKING</span>
    </div>
</div>

<!-- Leaflet Map Integration & Command Center Logic -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        if (document.getElementById('commandCenterMap')) {
            // Initialize map to Hyderabad by default
            var map = L.map('commandCenterMap').setView([17.3850, 78.4867], 13);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(map);

            // Fetch alerts from the backend payload dumped into the view
            var alertsData = @Html.Raw(alerts.ToString());
            var bounds = [];

            alertsData.forEach(function(alert) {
                if (alert.status !== 'Active') return; // Only plot active alerts

                // Try to extract Lat/Lng
                var match = alert.location.match(/\[Lat:([^,]+),\s*Lng:([^\]]+)\]/);
                var lat, lng;
                
                if (match) {
                    lat = parseFloat(match[1]);
                    lng = parseFloat(match[2]);
                } else {
                    // Fallback for legacy records without GPS
                    var locStr = alert.location.toLowerCase();
                    if (locStr.includes('hyderabad')) {
                        lat = 17.3850 + (Math.random() - 0.5) * 0.05;
                        lng = 78.4867 + (Math.random() - 0.5) * 0.05;
                    } else if (locStr.includes('mumbai')) {
                        lat = 19.0760 + (Math.random() - 0.5) * 0.05;
                        lng = 72.8777 + (Math.random() - 0.5) * 0.05;
                    } else if (locStr.includes('pune')) {
                        lat = 18.5204 + (Math.random() - 0.5) * 0.05;
                        lng = 73.8567 + (Math.random() - 0.5) * 0.05;
                    } else if (locStr.includes('chennai')) {
                        lat = 13.0827 + (Math.random() - 0.5) * 0.05;
                        lng = 80.2707 + (Math.random() - 0.5) * 0.05;
                    } else if (locStr.includes('delhi') || locStr.includes('noida') || locStr.includes('gurugram')) {
                        lat = 28.6139 + (Math.random() - 0.5) * 0.05;
                        lng = 77.2090 + (Math.random() - 0.5) * 0.05;
                    } else if (locStr.includes('bangalore') || locStr.includes('bengaluru')) {
                        lat = 12.9716 + (Math.random() - 0.5) * 0.05;
                        lng = 77.5946 + (Math.random() - 0.5) * 0.05;
                    } else {
                        // Default to Hyderabad if no GPS and no recognized city
                        lat = 17.3850 + (Math.random() - 0.5) * 0.05;
                        lng = 78.4867 + (Math.random() - 0.5) * 0.05;
                    }
                }

                var severityColor = alert.severity === 'Critical' ? '#ef4444' : (alert.severity === 'High' ? '#f59e0b' : '#3b82f6');
                var animationClass = alert.severity === 'Critical' ? 'pulse-sos' : '';

                var customIcon = L.divIcon({
                    className: 'custom-map-icon',
                    html: `<div style="width: 20px; height: 20px; background: ${severityColor}; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 15px ${severityColor}; animation: ${animationClass} 1.5s infinite;"></div>`,
                    iconSize: [20, 20],
                    iconAnchor: [10, 10]
                });

                var marker = L.marker([lat, lng], {icon: customIcon}).addTo(map);
                bounds.push([lat, lng]);

                var cleanLocation = alert.location.replace(/\[Lat:.*\]/, '').trim();
                
                marker.bindPopup(`
                    <div style="min-width: 150px;">
                        <span class="badge bg-dark text-white mb-2 border border-secondary" style="font-family:monospace;">Alert #${alert.id}</span>
                        <h6 style="color:#0f172a; margin-bottom:4px; font-weight:bold; font-size:14px;">${cleanLocation}</h6>
                        <span style="color:${severityColor}; font-size:12px; font-weight:bold; text-transform:uppercase;">${alert.severity} SEVERITY</span><br>
                        <span style="color:#64748b; font-size:11px;">Employee ID: ${alert.employeeId}</span>
                    </div>
                `);
            });

            // Auto-zoom map to fit all active emergencies
            if (bounds.length > 0) {
                map.fitBounds(bounds, { padding: [50, 50], maxZoom: 16 });
            }
        }
    });
</script>

<div class="glass-card">
    <h5 class="section-title text-danger">🚨 All Emergency Alerts</h5>

    @if (!alerts.EnumerateArray().Any())
    {
        <div class="empty-state py-5">
            <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 24px; animation: float 6s ease-in-out infinite;">✅</div>
            <h5 class="text-white">All clear</h5>
            <p class="text-muted">There are no emergency alerts at this time.</p>
        </div>
    }
    else
    {
        <style>
            .sos-card {
                background: rgba(15, 23, 42, 0.6);
                border: 1px solid rgba(255,255,255,0.05);
                border-left: 4px solid var(--ss-alert);
                border-radius: 12px;
                padding: 24px;
                margin-bottom: 20px;
                transition: all 0.3s ease;
            }
            .sos-card.resolved {
                border-left-color: #10b981;
            }
            .sos-timeline {
                display: flex;
                justify-content: space-between;
                position: relative;
                margin-top: 24px;
                padding-top: 24px;
                border-top: 1px dashed rgba(255,255,255,0.1);
            }
            .sos-step {
                text-align: center;
                position: relative;
                flex: 1;
            }
            .sos-step::after {
                content: '';
                position: absolute;
                top: 12px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: rgba(255,255,255,0.1);
                z-index: 1;
            }
            .sos-step:last-child::after { display: none; }
            
            .sos-icon {
                width: 24px;
                height: 24px;
                border-radius: 50%;
                background: var(--ss-bg);
                border: 2px solid rgba(255,255,255,0.2);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                color: transparent;
                position: relative;
                z-index: 2;
                margin-bottom: 8px;
            }
            .sos-step.completed .sos-icon {
                background: rgba(16, 185, 129, 0.2);
                border-color: #10b981;
                color: #10b981;
                box-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
            }
            .sos-step.active .sos-icon {
                background: rgba(239, 68, 68, 0.2);
                border-color: var(--ss-alert);
                color: var(--ss-alert);
                box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
                animation: pulse-sos 2s infinite;
            }
            .sos-label {
                font-size: 11px;
                font-weight: 600;
                color: var(--ss-muted);
                text-transform: uppercase;
            }
            .sos-step.completed .sos-label { color: rgba(255,255,255,0.8); }
            .sos-step.active .sos-label { color: var(--ss-alert); }
        </style>

        <div class="mt-4">
            @foreach (var a in alerts.EnumerateArray())
            {
                var id = a.GetProperty("id").GetInt32();
                var empId = a.GetProperty("employeeId").GetString();
                var location = a.GetProperty("location").GetString();
                var description = a.GetProperty("description").GetString();
                var severity = a.GetProperty("severity").GetString();
                var status = a.GetProperty("status").GetString() ?? "Active";
                var triggeredAt = a.GetProperty("triggeredAt").GetString();

                var isResolved = status == "Resolved";
                var severityClass = severity == "Critical" ? "error" : severity == "High" ? "warning" : "info";

                <div class="sos-card @(isResolved ? "resolved" : "") fade-in-up">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;"><i class="bi bi-person me-1"></i>Emp: @empId</span>
                                <span class="status-chip @severityClass px-2 py-0" style="font-size: 10px;">@severity Severity</span>
                            </div>
                            <h5 class="text-white fw-bold mb-1"><i class="bi bi-geo-alt text-danger me-1"></i>@location</h5>
                            <div style="font-size: 12px; color: var(--ss-muted);">
                                <i class="bi bi-clock me-1"></i> Triggered @TimeHelper.ToIST(triggeredAt!).ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <span class="status-chip @(isResolved ? "success" : "error") px-3 py-1 fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                @if(!isResolved) { <span style="width:8px;height:8px;border-radius:50%;background:currentColor;display:inline-block;animation:pulse-sos 1s infinite;"></span> }
                                @status
                            </span>
                            @if (status == "Active" && (role == "Security" || role == "Admin"))
                            {
                                <form method="post" asp-action="Resolve" class="m-0">
                                    <input type="hidden" name="alertId" value="@id" />
                                    <button type="submit" class="btn-ss-outline" style="padding: 4px 12px; font-size: 12px; border-color: #10b981; color: #10b981;">
                                        <i class="bi bi-check2-all me-1"></i>Mark Resolved
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                    
                    <p class="mb-0 text-white opacity-75" style="font-size: 14px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 8px;">
                        @description
                    </p>

                    <div class="sos-timeline">
                        <div class="sos-step completed">
                            <div class="sos-icon"><i class="bi bi-broadcast"></i></div>
                            <div class="sos-label">Alert Triggered</div>
                        </div>
                        <div class="sos-step @(isResolved ? "completed" : "active")">
                            <div class="sos-icon"><i class="bi @(isResolved ? "bi-check-lg" : "bi-shield-exclamation")"></i></div>
                            <div class="sos-label">Security Dispatched</div>
                        </div>
                        <div class="sos-step @(isResolved ? "completed" : "")">
                            <div class="sos-icon"><i class="bi bi-shield-check"></i></div>
                            <div class="sos-label">Incident Resolved</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

