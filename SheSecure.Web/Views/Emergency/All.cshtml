@{
    ViewData["Title"] = "SOS Alerts";
    var alerts = (System.Text.Json.JsonElement)ViewBag.Alerts;
    var role = Context.Session.GetString("Role") ?? "";
}

@if (TempData["Success"] != null)
{
    <div class="alert-glass success mb-4">
        <i class="bi bi-check-circle fs-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-glass error mb-4">
        <i class="bi bi-exclamation-circle fs-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="glass-card mt-2">
    <h5 class="section-title text-danger">🚨 Active Emergency Alerts</h5>

    @if (!alerts.EnumerateArray().Any())
    {
        <div class="empty-state py-5">
            <div class="empty-state-icon" style="font-size: 64px; margin-bottom: 24px; animation: float 6s ease-in-out infinite;">✅</div>
            <h5 class="text-white">All clear</h5>
            <p class="text-muted">There are no emergency alerts at this time.</p>
        </div>
    }
    else
    {
        <style>
            .sos-card {
                background: rgba(15, 23, 42, 0.6);
                border: 1px solid rgba(255,255,255,0.05);
                border-left: 4px solid var(--ss-alert);
                border-radius: 12px;
                padding: 24px;
                margin-bottom: 20px;
                transition: all 0.3s ease;
            }
            .sos-card.resolved {
                border-left-color: #10b981;
            }
            .sos-timeline {
                display: flex;
                justify-content: space-between;
                position: relative;
                margin-top: 24px;
                padding-top: 24px;
                border-top: 1px dashed rgba(255,255,255,0.1);
            }
            .sos-step {
                text-align: center;
                position: relative;
                flex: 1;
            }
            .sos-step::after {
                content: '';
                position: absolute;
                top: 12px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: rgba(255,255,255,0.1);
                z-index: 1;
            }
            .sos-step:last-child::after { display: none; }
            
            .sos-icon {
                width: 24px;
                height: 24px;
                border-radius: 50%;
                background: var(--ss-bg);
                border: 2px solid rgba(255,255,255,0.2);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                color: transparent;
                position: relative;
                z-index: 2;
                margin-bottom: 8px;
            }
            .sos-step.completed .sos-icon {
                background: rgba(16, 185, 129, 0.2);
                border-color: #10b981;
                color: #10b981;
                box-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
            }
            .sos-step.active .sos-icon {
                background: rgba(239, 68, 68, 0.2);
                border-color: var(--ss-alert);
                color: var(--ss-alert);
                box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
                animation: pulse-sos 2s infinite;
            }
            .sos-label {
                font-size: 11px;
                font-weight: 600;
                color: var(--ss-muted);
                text-transform: uppercase;
            }
            .sos-step.completed .sos-label { color: rgba(255,255,255,0.8); }
            .sos-step.active .sos-label { color: var(--ss-alert); }
        </style>

        <div class="mt-4 row">
            @foreach (var a in alerts.EnumerateArray())
            {
                var id = a.GetProperty("id").GetInt32();
                var empId = a.GetProperty("employeeId").GetString();
                var location = a.GetProperty("location").GetString();
                var description = a.GetProperty("description").GetString();
                var severity = a.GetProperty("severity").GetString();
                var status = a.GetProperty("status").GetString() ?? "Active";
                var triggeredAt = a.GetProperty("triggeredAt").GetString();
                string resolutionNotes = "";
                if (a.TryGetProperty("resolutionNotes", out var rNotes) && rNotes.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    resolutionNotes = rNotes.GetString() ?? "";
                }

                var isResolved = status == "Resolved";
                var severityClass = severity == "Critical" ? "error" : severity == "High" ? "warning" : "info";

                <div class="col-md-6 mb-3">
                    <div class="sos-card h-100 @(isResolved ? "resolved" : "") fade-in-up">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;">#@id</span>
                                    <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--ss-muted); font-family: monospace;"><i class="bi bi-person me-1"></i>Emp: @empId</span>
                                    <span class="status-chip @severityClass px-2 py-0" style="font-size: 10px;">@severity Severity</span>
                                </div>
                                @{
                                    var displayLocation = System.Text.RegularExpressions.Regex.Replace(location ?? "", @"\[Lat:.*\]", "").Trim();
                                }
                                <h5 class="text-white fw-bold mb-1"><i class="bi bi-geo-alt text-danger me-1"></i>@displayLocation</h5>
                                <div style="font-size: 12px; color: var(--ss-muted);">
                                    <i class="bi bi-clock me-1"></i> Triggered @TimeHelper.ToIST(triggeredAt!).ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-2">
                                <span class="status-chip @(isResolved ? "success" : "error") px-3 py-1 fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                    @if(!isResolved) { <span style="width:8px;height:8px;border-radius:50%;background:currentColor;display:inline-block;animation:pulse-sos 1s infinite;"></span> }
                                    @status
                                </span>
                            </div>
                        </div>
                        
                        <p class="mb-3 text-white opacity-75" style="font-size: 14px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 8px;">
                            @description
                        </p>

                        @if (isResolved && !string.IsNullOrEmpty(resolutionNotes))
                        {
                            <div class="mt-3 p-3 rounded" style="background: rgba(16, 185, 129, 0.1); border-left: 3px solid #10b981;">
                                <h6 class="text-success fw-bold mb-1" style="font-size: 12px;"><i class="bi bi-journal-text me-1"></i> Resolution Notes</h6>
                                <p class="mb-0 text-white opacity-75" style="font-size: 13px;">@resolutionNotes</p>
                            </div>
                        }

                        <!-- Quick Actions Row -->
                        @if (!isResolved && (role == "Security" || role == "Admin"))
                        {
                            <div class="d-flex gap-2 mb-3 mt-3">
                                <button type="button" class="btn btn-sm ms-auto" style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; color: #10b981; font-size: 12px; font-weight: bold;" data-bs-toggle="modal" data-bs-target="#resolveModal-@id">
                                    <i class="bi bi-check2-all me-1"></i> Mark Resolved
                                </button>
                            </div>

                            <!-- Resolve Modal -->
                            <div class="modal fade" id="resolveModal-@id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content glass-card border-0" style="background: var(--ss-bg); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                                        <div class="modal-header border-secondary border-opacity-25">
                                            <h5 class="modal-title text-success"><i class="bi bi-shield-check me-2"></i> Resolve Alert #@id</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <form method="post" asp-action="Resolve">
                                            <div class="modal-body">
                                                <input type="hidden" name="alertId" value="@id" />
                                                <div class="mb-3">
                                                    <label class="form-label text-muted" style="font-size: 13px;">Action Log / Resolution Notes <span class="text-danger">*</span></label>
                                                    <textarea class="form-control" name="resolutionNotes" rows="4" required placeholder="Describe the actions taken to secure the employee and resolve this emergency..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-secondary border-opacity-25">
                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i> Confirm Resolution</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="sos-timeline mt-auto">
                            <div class="sos-step completed">
                                <div class="sos-icon"><i class="bi bi-broadcast"></i></div>
                                <div class="sos-label">Alert Triggered</div>
                            </div>
                            <div class="sos-step @(isResolved ? "completed" : "active")">
                                <div class="sos-icon"><i class="bi @(isResolved ? "bi-check-lg" : "bi-shield-exclamation")"></i></div>
                                <div class="sos-label">Security Dispatched</div>
                            </div>
                            <div class="sos-step @(isResolved ? "completed" : "")">
                                <div class="sos-icon"><i class="bi bi-shield-check"></i></div>
                                <div class="sos-label">Incident Resolved</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

